---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroTemple from "../../components/content/HeroTemple.astro";
import PhotoSlider from "../../components/content/PhotoSlider.astro";
import RotatingQuote from "../../components/content/RotatingQuote.astro";
import ThreeDoors from "../../components/content/ThreeDoors.astro";
import UpcomingEvent from "../../components/content/UpcomingEvent.astro";
import ContactCTA from "../../components/content/ContactCTA.astro";
import { t } from "../../i18n/ui";

const lang = "es" as const;

// Hero ya muestra templo-3 (salón principal). Slider arranca con foto distinta
// para no duplicar visualmente el primer impacto.
const sliderPhotos = [
  { src: "/assets/templo/templo-1.jpeg", alt: "Delta luminoso dorado con el Ojo de la Providencia", caption: "Delta Luminoso del Templo, sobre fondo bermellón" },
  { src: "/assets/templo/templo-2.jpeg", alt: "Fachada del Templo Hijos del Trabajo en Barracas, estilo egipcio (1919)", caption: "Fachada egipcia del Templo Hijos del Trabajo — Francisco Cabot, 1919" },
  { src: "/assets/templo/templo-4.jpeg", alt: "Detalle del techo y la araña principal del Templo", caption: "Bóveda celeste y araña principal del Templo" },
  { src: "/assets/templo/templo-3.jpeg", alt: "Salón principal del Templo Hijos del Trabajo, vista general", caption: "Salón principal del Templo — bóveda celeste pintada al fresco" },
];
---

<BaseLayout
  lang={lang}
  title="Unión Italiana N°12 — Logia Masónica Buenos Aires desde 1858"
  description="Logia masónica regular de Buenos Aires fundada en 1858. Afiliada a la Gran Logia de la Argentina. Templo Hijos del Trabajo, Barracas. Ingreso, peticiones y contacto."
  noTitleSuffix={true}
  schemaType="Organization"
  ogImageAlt="Delta Luminoso del Templo Hijos del Trabajo — R∴L∴ Unión Italiana N°12, Logia Masónica de Buenos Aires"
>
  <HeroTemple
    lang={lang}
    eyebrow={t("home.hero.eyebrow", lang)}
    title={t("home.hero.title", lang)}
    subtitle={t("home.hero.subtitle", lang)}
    ctaLabel={t("home.hero.cta", lang)}
    ctaHref="/es/la-logia/templo/"
  />

  <UpcomingEvent lang={lang} />

  <section class="container container-narrow" style="padding-block: var(--space-12);">
    <p class="lead drop-cap">
      Somos una sociedad filantrópica, filosófica y progresista. Trabajamos
      en Buenos Aires desde el 23 de diciembre de 1858 (e∴v∴) — el mismo año en que
      la Unione e Benevolenza abría sus puertas con el padrinazgo simbólico de Mazzini y
      Garibaldi. Nuestro primer Presidente fue el médico genovés José Salvarezza,
      presente en la asistencia durante el cólera de 1867 (e∴v∴) y la fiebre amarilla de 1871 (e∴v∴).
      Refundada en 2014 (e∴v∴) a partir de un núcleo preocupado por la falta de presencia de la
      Orden en La Boca, la R∴L∴ Unión Italiana N°12 sostiene hoy sus reuniones en el histórico
      Templo Hijos del Trabajo de Barracas, afiliada a la Gran Logia de la
      Argentina de Libres y Aceptados Masones.
    </p>
  </section>

  <section class="container" style="padding-bottom: var(--space-12);">
    <PhotoSlider photos={sliderPhotos} aspect="16 / 9" autoplayMs={6000} />
  </section>

  <ThreeDoors
    doors={[
      { href: "/es/la-logia/historia/", glyph: "columns", eyebrow: "MDCCCLVIII — Hoy", title: t("home.three_doors.history", lang), text: "Una historia documentada, no mítica. Del Risorgimento a la refundación de 2014 (e∴v∴)." },
      { href: "/es/masoneria/que-es/", glyph: "delta", eyebrow: "Una Orden filosófica", title: t("home.three_doors.masonry", lang), text: "Qué es —y qué no es— la masonería regular. Sin secretos, con reservas." },
      { href: "/es/ingreso/", glyph: "square-compass", eyebrow: "Umbral del Peticionario", title: t("home.three_doors.initiation", lang), text: "Si llegó hasta aquí por algo más que curiosidad pasajera, pase y lea con atención." },
    ]}
  />

  <RotatingQuote lang={lang} />

  <div class="divider-fleuron" aria-hidden="true">
    <span class="divider-fleuron-glyph">✦</span>
  </div>

  <ContactCTA lang={lang} variant="full" />
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--fg);
  }
</style>
