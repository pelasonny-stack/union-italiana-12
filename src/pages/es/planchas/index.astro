---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import Stub from "../../../components/content/Stub.astro";
import { getCollection } from "astro:content";

const lang = "es" as const;
const all = await getCollection("planchas", ({ id, data }) => id.startsWith("es/") && !data.draft);
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  lang={lang}
  title="Planchas Masónicas — Trabajos Escritos Publicados"
  description="Planchas masónicas de Unión Italiana N°12: estudios, reflexiones y trabajos escritos publicados conforme al Reglamento de la Gran Logia de la Argentina."
  breadcrumb={[{ name: "Planchas", url: "/es/planchas/" }]}
>
  <PageHero
    eyebrow="Trabajos escritos"
    title="Planchas"
    subtitle="Estudios y reflexiones publicadas conforme al reglamento"
    glyph="three-dots"
  />

  <article class="container container-prose" style="padding-block: var(--space-8);">
    {sorted.length === 0 ? (
      <Stub note="Aún no se han publicado planchas en este sitio. Cuando aparezcan, cada trabajo llevará al pie la firma responsable, las fuentes citadas y el aviso reglamentario conforme al Art. 7° del Reglamento Especial de Publicación de Páginas Web en Internet de la Gran Logia de la Argentina." />
    ) : (
      <ul class="plancha-list">
        {sorted.map((p) => (
          <li>
            <a href={`/es/planchas/${p.id.replace("es/", "").replace(/\.(md|mdx)$/, "")}/`}>
              <span class="overline">{p.data.date.getUTCFullYear()} (e∴v∴)</span>
              <span class="cinzel plancha-title">{p.data.title}</span>
              <span class="plancha-excerpt">{p.data.excerpt}</span>
              <span class="plancha-author">— {p.data.author}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  .plancha-list { list-style: none; padding: 0; margin: 0; }
  .plancha-list li {
    border-top: 1px solid var(--border);
    padding-block: var(--space-4);
  }
  .plancha-list li:last-child { border-bottom: 1px solid var(--border); }
  .plancha-list a {
    display: grid;
    gap: var(--space-1);
    background-image: none;
  }
  .plancha-title {
    font-size: 1.15rem;
    color: var(--fg);
  }
  .plancha-excerpt {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .plancha-author {
    font-size: 0.78rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }
</style>
