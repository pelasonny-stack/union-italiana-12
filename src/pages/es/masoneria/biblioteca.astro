---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import NavRelated from "../../../components/content/NavRelated.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "es" as const;
---

<BaseLayout
  lang={lang}
  title="Biblioteca Masónica — Anderson, Ingenieros, Mackey, Lavagnini"
  description="Biblioteca masónica: Constituciones de Anderson (1723 e∴v∴), José Ingenieros, Mackey, Lavagnini. Textos en dominio público, bibliografía y descargas."
  breadcrumb={[
    { name: "Masonería", url: "/es/masoneria/" },
    { name: "Biblioteca", url: "/es/masoneria/biblioteca/" },
  ]}
  article={{
    section: "Biblioteca",
    keywords: ["biblioteca masonería", "textos masónicos", "constituciones de anderson", "josé ingenieros libros", "bibliografía masónica"],
  }}
>
  <PageHero eyebrow="Lecturas" title="Biblioteca" subtitle="Per chi vuole approfondire" glyph="letter-g" />

  <article class="container container-prose" style="padding-block: var(--space-8);">
    <h2>Textos fundacionales</h2>
    <ul>
      <li><strong>Constituciones de Anderson (1723 (e∴v∴))</strong> — texto fundacional de la masonería moderna. Dominio público.</li>
      <li><strong>The Symbolism of Freemasonry</strong> — Albert G. Mackey (1869 (e∴v∴)). Dominio público.</li>
      <li><strong>Manual del Aprendiz</strong> — Aldo Lavagnini (varias ediciones). Trabajo introductorio clásico.</li>
    </ul>

    <h2>Masones argentinos</h2>
    <ul>
      <li><strong>El hombre mediocre</strong> — José Ingenieros (1913). Dominio público.</li>
      <li><strong>Las fuerzas morales</strong> — José Ingenieros (1925, póstumo).</li>
      <li><strong>Hacia una moral sin dogmas</strong> — José Ingenieros (1917).</li>
    </ul>

    <h2>Bibliografía académica</h2>
    <ul>
      <li>Lappas, Alcibíades — <em>La Masonería Argentina a través de sus hombres</em>.</li>
      <li>Ferrer Benimeli, José — <em>Masonería e Inquisición en Latinoamérica</em>.</li>
      <li>Devoto, Fernando — <em>Historia de la inmigración italiana en la Argentina</em>.</li>
    </ul>

    <Stub note="Los enlaces a los PDF en dominio público se cargarán a medida que se digitalicen y verifiquen las versiones autorizadas." />
  </article>

  <NavRelated
    lang={lang}
    prev={{ href: "/es/masoneria/glosario/", label: "Glosario" }}
    index={{ href: "/es/masoneria/", label: "Masonería" }}

  />
</BaseLayout>
