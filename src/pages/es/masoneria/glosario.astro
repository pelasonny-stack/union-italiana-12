---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import NavRelated from "../../../components/content/NavRelated.astro";
const lang = "es" as const;

const terms = [
  { term: "Aprendiz", def: "Primer grado de la masonería simbólica. Su trabajo se centra en el desbastado de la piedra bruta — el simbolismo del trabajo sobre el carácter en sus aspectos más elementales." },
  { term: "Cadena de Unión", def: "Acto fraternal con que se cierran determinadas reuniones. Su descripción precisa pertenece al ámbito de la práctica ritual y no se publica; su sentido —la afirmación material del lazo entre los miembros presentes y con los ausentes— sí." },
  { term: "Columnas Jakin y Boaz", def: "Las dos columnas del pórtico del Templo de Salomón, según el relato bíblico (1 Reyes 7:21). En la masonería simbolizan la dualidad estabilidad/fuerza y son referencia constante del trabajo en Logia." },
  { term: "Constituciones de Anderson", def: "Texto fundacional de la masonería moderna (1723 (e∴v∴)), redactado por el pastor presbiteriano James Anderson y publicado por la Gran Logia de Londres. Documento de dominio público disponible en nuestra biblioteca." },
  { term: "Gran Arquitecto del Universo (G∴A∴D∴U∴)", def: "Fórmula con que la masonería regular nombra al Principio Creador. Es deliberadamente abierta: cada miembro la entiende en el marco de su propia tradición religiosa o filosófica." },
  { term: "Gran Logia", def: "Cuerpo soberano que agrupa a las logias de un territorio. Esta Logia trabaja bajo la jurisdicción de la Gran Logia de la Argentina de Libres y Aceptados Masones." },
  { term: "Logia (Loggia)", def: "Tanto el cuerpo de masones reunidos en trabajo regular cuanto el lugar donde se reúnen. La palabra remite al sitio donde los antiguos canteros guardaban sus herramientas y deliberaban sobre la obra." },
  { term: "Maestro Masón", def: "Tercer grado de la masonería simbólica. Quien lo recibe asume la plenitud de los derechos y responsabilidades en la Orden." },
  { term: "Oriente", def: "Designa la ciudad o territorio donde se asienta una Logia (\"Buenos Aires\"). Por extensión, la parte del Templo donde se sitúa el Presidente durante las sesiones." },
  { term: "Plancha (Tavola)", def: "Trabajo escrito que un miembro elabora sobre un tema y presenta a la Logia. Es el modo principal en que el masón da cuenta de su estudio y reflexión." },
  { term: "Profano", def: "En el lenguaje de la Orden, designa a quien no ha sido iniciado, sin connotación peyorativa. Del latín pro fanum — \"delante del templo\"." },
  { term: "Reunión", def: "Sesión de trabajo de una Logia. Las hay regulares (sólo para masones) y blancas (públicas)." },
  { term: "Reunión abierta", def: "Sesión pública a la que la Logia invita a no-masones — habitualmente con motivo de una conferencia. Es el principal canal de contacto con el mundo profano." },
  { term: "Tolerancia", def: "En la tradición masónica, no es indiferencia ni relativismo: es la disposición activa a sostener el diálogo entre hombres de convicciones diversas, a partir del reconocimiento de la dignidad común." },
  { term: "VITRIOL", def: "Acrónimo latino: Visita Interiora Terrae Rectificando Invenies Occultum Lapidem. \"Visita el interior de la tierra y, rectificando, hallarás la piedra oculta.\" Antigua fórmula alquímica adoptada por la masonería para describir el trabajo del iniciado sobre sí mismo." },
];
---

<BaseLayout lang={lang} title="Glosario masónico" description="Quince términos clave de la masonería regular, definidos públicamente y sin revelar lo reservado.">
  <PageHero eyebrow="Quince términos" title="Glosario" subtitle="Definiciones públicas, verificables, sobrias" glyph="three-dots" />

  <article class="container container-prose" style="padding-block: var(--space-8);">
    <p class="container-prose">
      Las definiciones siguientes provienen de fuentes públicas (Mackey, Lavagnini) y
      están al alcance de cualquier diccionario masónico publicado. Lo reservado —modos
      de reconocimiento, palabras, ritualística específica— no figura en este glosario.
    </p>
    <dl class="glossary">
      {terms.map(({ term, def }) => (
        <>
          <dt>{term}</dt>
          <dd>{def}</dd>
        </>
      ))}
    </dl>
  </article>

  <NavRelated
    lang={lang}
    prev={{ href: "/es/masoneria/principios/", label: "Principios" }}
    index={{ href: "/es/masoneria/", label: "Masonería" }}
    next={{ href: "/es/masoneria/biblioteca/", label: "Biblioteca" }}
  />
</BaseLayout>

<style>
  .glossary {
    margin-top: var(--space-8);
    counter-reset: glossary;
    display: grid;
    grid-template-columns: 64px 1fr;
    column-gap: var(--space-3);
  }
  .glossary dt {
    counter-increment: glossary;
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    align-items: baseline;
    font-family: var(--font-display);
    font-size: var(--text-h5);
    color: var(--fg);
    margin-top: var(--space-6);
  }
  .glossary dt::before {
    content: counter(glossary, upper-roman) ".";
    grid-column: 1;
    font-family: var(--font-cinzel);
    font-size: 1.1rem;
    color: var(--accent);
    text-align: right;
    letter-spacing: 0.04em;
  }
  .glossary dt::after {
    content: "";
    grid-column: 2;
    display: block;
    height: 1px;
    width: 88px;
    background: var(--accent);
    opacity: 0.3;
    margin-top: 6px;
  }
  .glossary dt > * {
    grid-column: 2;
  }
  .glossary dt:first-of-type { margin-top: 0; }
  .glossary dt:first-of-type::after { display: none; }
  .glossary dd {
    grid-column: 2;
    margin: var(--space-1) 0 var(--space-3);
    color: var(--fg-muted);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  @media (max-width: 600px) {
    .glossary { grid-template-columns: 1fr; }
    .glossary dt { display: block; }
    .glossary dt::before { display: inline; margin-right: 0.5em; }
    .glossary dt::after { display: none; }
    .glossary dd { padding-left: 1em; }
  }
</style>
