---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import NavRelated from "../../../components/content/NavRelated.astro";
import Quote from "../../../components/content/Quote.astro";
const lang = "es" as const;
const currentYear = new Date().getUTCFullYear();
const yearsActive = currentYear - 1858;
// Convertir años a italiano para subtitle
const itNumber = (n: number): string => {
  const ones = ["", "uno", "due", "tre", "quattro", "cinque", "sei", "sette", "otto", "nove"];
  const tens = ["", "dieci", "venti", "trenta", "quaranta", "cinquanta", "sessanta", "settanta", "ottanta", "novanta"];
  if (n < 100) {
    if (n < 10) return ones[n] ?? String(n);
    if (n < 20) {
      const teens = ["dieci", "undici", "dodici", "tredici", "quattordici", "quindici", "sedici", "diciassette", "diciotto", "diciannove"];
      return teens[n - 10] ?? String(n);
    }
    const t = Math.floor(n / 10), o = n % 10;
    return (tens[t] ?? "") + (o ? (o === 1 || o === 8 ? (tens[t]?.slice(0, -1) ?? "") + (ones[o] ?? "") : (ones[o] ?? "")) : "");
  }
  if (n < 200) return "cento" + (n > 100 ? itNumber(n - 100) : "");
  return String(n);
};
const yearsItalian = itNumber(yearsActive);

const milestones = [
  { year: "1858 (e∴v∴) · 23·XII", title: "Fundación", text: "Se inauguran las actividades de la Logia bajo el nombre original de Unione Italiana, con sesiones en italiano. Primer Presidente: el médico genovés José Salvarezza, graduado en la Universidad de Buenos Aires (1866 (e∴v∴)) y figura prominente de la colectividad italiana porteña." },
  { year: "1858 (e∴v∴) · año bisagra", title: "Mutual y Logia", text: "Cinco meses antes, el 18 de julio, había abierto sus puertas la Unione e Benevolenza —primera Sociedad Italiana de Mutuo Soccorso de Sudamérica— bajo el padrinazgo simbólico de Mazzini y Garibaldi. Mutual y Logia: dos manos de la misma comunidad italiana." },
  { year: "1867 (e∴v∴) · cólera", title: "Primera epidemia", text: "Salvarezza atiende sin cobrar a las víctimas de la epidemia de cólera, particularmente a los inmigrantes hacinados en La Boca y Barracas." },
  { year: "1871 (e∴v∴) · 27·I — 11·VI", title: "Fiebre amarilla", text: "Se desata la epidemia que mata a 14.000 personas en Buenos Aires, 9.000 de ellas italianas. Los miembros de la Logia se suman a la Comisión Popular presidida por Roque Pérez —Gran Maestro, fallecido en cumplimiento del deber. Salvarezza no se ausenta del frente sanitario." },
  { year: "1872 (e∴v∴) · Hospital Italiano", text: "Las logias italianas sostienen los años difíciles del Hospital Italiano —fundado en 1853 (e∴v∴) con piedra fundamental en 1854 (e∴v∴)— en su consolidación institucional." },
  { year: "1876 (e∴v∴)—1877 (e∴v∴) · cisma", title: "Unione Italiana II", text: "Una mayoría de miembros solicita el ingreso al Gran Oriente de Italia: el 23 de marzo de 1877 (e∴v∴) nace la Unione Italiana II. La fusión posterior reunirá más de 600 miembros." },
  { year: "1882 (e∴v∴) · 19·XI", title: "Fundación de La Plata", text: "En la piedra fundamental de la nueva capital provincial se deposita un medallón de la Unione Italiana, junto a otros de logias contemporáneas. La obra es dirigida por Dardo Rocha, masón él mismo, con trazado de Pedro Benoit." },
  { year: "1898 (e∴v∴) · 5·VIII", title: "José Ingenieros", text: "El joven José Ingenieros, hijo del periodista siciliano Salvatore Ingegnieros, se inicia en la Logia Unión Italiana Primera Nº 90 —rama derivada del cisma— al alcanzar la mayoría de edad. Será Gran Hospitalario de la masonería argentina en 1901-1902 y autor de El hombre mediocre (1913)." },
  { year: "Siglo XX", title: "Continuidad y silencio", text: "Las dos guerras mundiales, los sucesivos golpes y los años de la última dictadura ponen a prueba la regularidad institucional. La Logia atraviesa períodos más visibles y otros más reservados." },
  { year: "1983 (e∴v∴) · 6·IV", title: "Disolución de Hijos del Trabajo", text: "Por Decreto 4228, la Gran Logia disuelve la R∴L∴ Hijos del Trabajo —fundada el 14 de mayo de 1882 (e∴v∴), consagrada en su templo de San Antonio 814 el 22 de junio de 1890 (e∴v∴)— tras 101 años de vida." },
  { year: "2003 (e∴v∴)", title: "Hijos del Trabajo Nº 74", text: "La Gran Logia autoriza el relevantamiento de columnas como R∴L∴ Hijos del Trabajo Nº 74, restituyendo la actividad ritual al templo histórico de Barracas." },
  { year: "2014 (e∴v∴)", title: "Refundación de la Unión Italiana N°12", text: "Un grupo de masones, preocupados por la falta de presencia de la Orden en La Boca —núcleo histórico de la inmigración italiana—, solicita autorización para reinstaurar la Unión Italiana. La Logia retoma su actividad regular en el mismo templo donde, casi siglo y medio antes, la colectividad italiana había levantado su tabernáculo." },
  { year: "Hoy", title: "En Buenos Aires", text: "Trabajamos los lunes en el histórico Templo Hijos del Trabajo, San Antonio 814, Barracas — afiliada a la Gran Logia de la Argentina de Libres y Aceptados Masones." },
];
---

<BaseLayout
  lang={lang}
  title="Historia — Fundación 1858 (e∴v∴), Refundación 2014 (e∴v∴)"
  description="Historia documentada de Unión Italiana N°12: fundación 1858 (e∴v∴) con José Salvarezza, fiebre amarilla 1871 (e∴v∴), José Ingenieros, refundación 2014 (e∴v∴)."
  breadcrumb={[
    { name: "La Logia", url: "/es/la-logia/" },
    { name: "Historia", url: "/es/la-logia/historia/" },
  ]}
  article={{
    datePublished: "2024-09-01",
    dateModified: "2026-04-01",
    section: "Historia",
    keywords: [
      "historia logia masónica buenos aires",
      "josé salvarezza médico",
      "josé ingenieros masón",
      "unión italiana 1858",
      "refundación 2014",
      "fiebre amarilla 1871",
      "fundación La Plata 1882",
      "Hospital Italiano",
    ],
  }}
>
  <PageHero
    eyebrow={`1858 (e∴v∴) — ${currentYear} (e∴v∴)`}
    title="Nuestra historia"
    subtitle={`${yearsItalian.charAt(0).toUpperCase() + yearsItalian.slice(1)} anni di lavoro`}
    glyph="columns"
  />

  <article class="container container-prose" style="padding-block: var(--space-8);">
    <p class="drop-cap">
      La Respetable Logia Unión Italiana N°12 nació en plena efervescencia del Risorgimento,
      cuando Italia aún no era una nación y miles de italianos cruzaban el Atlántico para
      hacer otra. Su nombre es programático: <em>unión</em>, no Italia. La Logia ha sido,
      desde entonces, espacio de encuentro entre la fraternidad masónica y la cultura
      asociativa italiana en la Argentina.
    </p>
  </article>

  {/* Línea de tiempo */}
  <section class="timeline-section">
    <div class="container container-narrow">
      <ol class="timeline">
        {milestones.map((m, i) => (
          <li class="ti-item" style={`--i: ${i};`}>
            <div class="ti-marker" aria-hidden="true">
              <span class="ti-dot"></span>
            </div>
            <div class="ti-content">
              <p class="overline ti-year">{m.year}</p>
              <h3 class="ti-title">{m.title}</h3>
              <p class="ti-text">{m.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="container container-prose" style="padding-block: var(--space-8);">
    <Quote
      text="Ogni uomo è figlio del suo lavoro."
      attribution="Lema del Templo Hijos del Trabajo, Barracas"
      lang="it"
    />

    <h2>Sobre el nombre y los nombres</h2>
    <p>
      Los archivos del XIX registran a la Logia como <em>Unione Italiana</em> (con la
      grafía italiana). Las sesiones se sostuvieron originalmente en italiano. Una rama
      derivada, la <em>Unión Italiana Primera N°90</em>, fue la que recibió a José
      Ingenieros en 1898 (e∴v∴). La numeración actual —N°12— responde al ordenamiento de la Gran
      Logia de la Argentina tras sus sucesivas reorganizaciones del siglo XX.
    </p>

    <h2>Material de archivo</h2>
    <p style="font-style: italic; color: var(--fg-muted)">
      Los documentos fundacionales, fotografías históricas y semblanzas de Venerables
      Maestros se publicarán a medida que el archivo de la Logia se digitalice. Para
      consultas académicas, escribir a
      <a href="mailto:unionitaliana12@gmail.com">unionitaliana12@gmail.com</a>.
    </p>
  </section>

  <NavRelated
    lang={lang}

    index={{ href: "/es/la-logia/", label: "La Logia" }}
    next={{ href: "/es/la-logia/vinculo-italiano/", label: "Vínculo italiano" }}
  />
</BaseLayout>

<style>
  .timeline-section {
    background: var(--bg-elevated);
    border-block: 1px solid var(--border);
    padding-block: var(--space-12);
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 11px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }
  .ti-item {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-3);
    padding-block: var(--space-4);
    position: relative;
  }
  .ti-marker {
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }
  .ti-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--bg-elevated), 0 0 0 5px var(--border);
  }
  .ti-year {
    color: var(--accent);
    margin-bottom: var(--space-1);
    font-family: var(--font-mono);
    text-transform: none;
    font-size: 0.85rem;
  }
  .ti-title {
    font-family: var(--font-display);
    font-size: var(--text-h5);
    font-weight: 500;
    margin: 0 0 var(--space-1);
  }
  .ti-text {
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.7;
  }

  /* Reveal stagger */
  @media (prefers-reduced-motion: no-preference) {
    .ti-item {
      opacity: 0;
      transform: translateY(8px);
      animation: ti-reveal 600ms var(--ease-ceremonial) forwards;
      animation-delay: calc(var(--i) * 80ms);
    }
    @keyframes ti-reveal {
      to { opacity: 1; transform: none; }
    }
  }
</style>
