---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "es" as const;

const miembros = [
  {
    name: "José Salvarezza",
    years: "siglo XIX",
    role: "Médico genovés, graduado en la Universidad de Buenos Aires en 1866 (e∴v∴). Primer Presidente de la Unión Italiana (1858 (e∴v∴)) y cofundador de la Unione e Benevolenza (julio de 1858 (e∴v∴)). Atendió gratuitamente las epidemias de cólera (1867 (e∴v∴)) y fiebre amarilla (1871 (e∴v∴)) en La Boca y Barracas. En 1873 (e∴v∴) fue Garante de Amistad para el Gran Oriente.",
    confirmed: true,
  },
  {
    name: "José Ingenieros",
    years: "1877 (e∴v∴)—1925",
    role: "Médico, psiquiatra, sociólogo y ensayista. Nacido Giuseppe en Palermo, llegó a Buenos Aires en 1885 (e∴v∴) con su padre. Lubetón desde 1888 (e∴v∴). Iniciado el 5 de agosto de 1898 (e∴v∴) en la Unión Italiana Primera N°90 —rama derivada del cisma— al alcanzar la mayoría de edad. Gran Hospitalario de la Gran Logia Argentina en 1901-1902. Autor de El hombre mediocre (1913), Hacia una moral sin dogmas (1917) y Las fuerzas morales (1925, póstumo).",
    confirmed: true,
  },
  {
    name: "Salvador Ingenieros",
    yearsFull: "Salvatore Ingegnieros Napolitano, 1850 (e∴v∴)—1922",
    years: "1850 (e∴v∴)—1922",
    role: "Sombrerero artesano de Palermo, Sicilia. Periodista socialista, perseguido en Italia. Cofundador en 1867 (e∴v∴) de la logia 'Giorgio Washington' antes de emigrar. Llegó a Buenos Aires en septiembre de 1885 (e∴v∴). Fundó y dirigió por años la Revista Masónica (que en 1904-1905 pasó a llamarse La Cadena de Unión). Volvió a Sicilia en 1916.",
    confirmed: true,
  },
  {
    name: "Giuseppe Garibaldi",
    years: "1807 (e∴v∴)—1882 (e∴v∴)",
    role: "Llegó al Río de la Plata en julio de 1837 (e∴v∴) al mando del corsario Mazzini. Ingresó como masón en Montevideo en agosto de 1844 (e∴v∴). Fundó logia en Gualeguay, Entre Ríos (1857 (e∴v∴)). Electo Gran Maestro del Gran Oriente de Italia en 1867 (e∴v∴); primer masón de Italia ad vitam en 1864 (e∴v∴). Sombra tutelar de toda logia italiana del Río de la Plata.",
    confirmed: false,
  },
  {
    name: "Roque Pérez",
    years: "1815 (e∴v∴)—1871 (e∴v∴)",
    role: "Gran Maestro de la masonería argentina. Presidió la Comisión Popular durante la fiebre amarilla de 1871 (e∴v∴); murió en cumplimiento del deber asistiendo a las víctimas. Vínculo cívico institucional, no miembro de esta Logia.",
    confirmed: false,
  },
  {
    name: "Francisco Tamburini",
    years: "1846 (e∴v∴)—1891 (e∴v∴)",
    role: "Arquitecto italiano nacido en Ascoli Piceno, llegó a Buenos Aires en 1881 (e∴v∴). Inspector General de Arquitectura Nacional desde 1883 (e∴v∴). Completó el Palacio Cangallo (sede actual de la Gran Logia, inaugurado en 1872 (e∴v∴)), firmó la ampliación de la Casa Rosada, el Teatro Colón en su primera etapa, el Hospital Militar y el Departamento Central de Policía. Masón confirmado.",
    confirmed: false,
  },
];
---

<BaseLayout lang={lang} title="Miembros ilustres" description="Figuras históricas de la R∴L∴ Unión Italiana N°12: José Ingenieros, Salvador Ingenieros, y otros vinculados culturalmente.">
  <PageHero eyebrow="Pasado documentado" title="Miembros ilustres" subtitle="Sólo personas fallecidas, sólo membresía documentada" glyph="letter-g" />

  <section class="container" style="padding-block: var(--space-8);">
    <p class="container-prose" style="margin: 0 auto var(--space-8);">
      Cada perfil cita fuentes verificables. Las personas marcadas como <em>vinculadas culturalmente</em>
      no fueron miembros formales de esta Logia, pero pertenecen al ecosistema masónico
      italo-argentino del que somos parte.
    </p>

    <ul class="miembros-grid">
      {miembros.map(m => (
        <li class="miembro-card">
          <p class="overline">{m.years}{m.confirmed ? " · Miembro confirmado" : " · Vínculo cultural"}</p>
          <h3>{m.name}</h3>
          {"yearsFull" in m && <p class="alt-name">{m.yearsFull}</p>}
          <p class="role">{m.role}</p>
        </li>
      ))}
    </ul>

    <Stub note="La lista completa será publicada cuando el archivero de la Logia confirme los registros del siglo XIX. Cada perfil tendrá su propia página con biografía extendida y bibliografía." />
  </section>
</BaseLayout>

<style>
  .miembros-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    max-width: var(--container-default);
    margin: 0 auto;
  }
  .miembro-card {
    padding: var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
  }
  .miembro-card h3 { margin: var(--space-1) 0; font-size: var(--text-h4); }
  .miembro-card .alt-name { color: var(--fg-subtle); font-style: italic; font-size: 0.85rem; margin: 0 0 var(--space-2); }
  .miembro-card .role { color: var(--fg-muted); margin: 0; }
</style>
