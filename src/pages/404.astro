---
import BaseLayout from "../layouts/BaseLayout.astro";
import MasonicGlyph from "../components/symbols/MasonicGlyph.astro";
import type { Locale } from "../i18n/config";

const path = Astro.url.pathname;
const lang: Locale = path.startsWith("/it") ? "it" : "es";

const copy = lang === "es"
  ? {
      title: "404",
      description: "Página no encontrada",
      quote: "\"Quien busca, encuentra; pero no siempre lo que buscaba.\"",
      back: "Volver al inicio",
      backHref: "/es/",
      altLinks: [
        { label: "Conocer la Logia", href: "/es/la-logia/" },
        { label: "Atrio del Peticionario", href: "/es/ingreso/peticion/" },
        { label: "Reuniones abiertas", href: "/es/actividades/reuniones-abiertas/" },
        { label: "Contacto", href: "/es/contacto/" },
      ],
      altLabel: "O acceder directamente",
    }
  : {
      title: "404",
      description: "Pagina non trovata",
      quote: "\"Chi cerca trova; ma non sempre ciò che cercava.\"",
      back: "Tornare all'inizio",
      backHref: "/it/",
      altLinks: [
        { label: "Conoscere la Loggia", href: "/it/la-loggia/" },
        { label: "Atrio del Postulante", href: "/it/ingresso/petizione/" },
        { label: "Riunioni aperte", href: "/it/attivita/riunioni-aperte/" },
        { label: "Contatti", href: "/it/contatti/" },
      ],
      altLabel: "O accedere direttamente",
    };
---

<BaseLayout lang={lang} title={copy.title} description={copy.description} noindex>
  <section class="container container-prose" style="padding-block: var(--space-16); text-align: center;">
    <MasonicGlyph name="three-dots" size={48} class="acacia" />
    <h1 style="margin-top: var(--space-4)">404</h1>
    <p style="font-family: var(--font-serif); font-style: italic; font-size: 1.25rem; color: var(--fg-muted)">
      {copy.quote}
    </p>
    <p style="margin-top: var(--space-4)">
      <a href={copy.backHref}>{copy.back}</a>
    </p>

    <p class="overline" style="margin-top: var(--space-8); color: var(--fg-muted)">{copy.altLabel}</p>
    <ul class="alt-list">
      {copy.altLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
  </section>
</BaseLayout>
<style>
  .acacia { color: var(--accent); margin: 0 auto; }
  .alt-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-3);
  }
  .alt-list a {
    font-family: var(--font-cinzel);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-uppercase);
    color: var(--accent);
    background-image: linear-gradient(var(--accent), var(--accent));
  }
</style>
