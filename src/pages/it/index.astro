---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroTemple from "../../components/content/HeroTemple.astro";
import PhotoSlider from "../../components/content/PhotoSlider.astro";
import RotatingQuote from "../../components/content/RotatingQuote.astro";
import ThreeDoors from "../../components/content/ThreeDoors.astro";
import UpcomingEvent from "../../components/content/UpcomingEvent.astro";
import ContactCTA from "../../components/content/ContactCTA.astro";
import { t } from "../../i18n/ui";

const lang = "it" as const;

// Hero mostra templo-3 (sala principale). Slider parte da foto diversa
// per non duplicare l'impatto visivo iniziale.
const sliderPhotos = [
  { src: "/assets/templo/templo-1.jpeg", alt: "Delta luminoso dorato con l'Occhio della Provvidenza", caption: "Delta Luminoso del Tempio, su fondo vermiglio" },
  { src: "/assets/templo/templo-2.jpeg", alt: "Facciata del Tempio Hijos del Trabajo a Barracas, stile egizio (1919)", caption: "Facciata egizia del Tempio Hijos del Trabajo — Francisco Cabot, 1919" },
  { src: "/assets/templo/templo-4.jpeg", alt: "Dettaglio del soffitto e del lampadario principale del Tempio", caption: "Volta celeste e lampadario principale del Tempio" },
  { src: "/assets/templo/templo-3.jpeg", alt: "Sala principale del Tempio Hijos del Trabajo, vista generale", caption: "Sala principale del Tempio — volta celeste affrescata" },
];
---

<BaseLayout
  lang={lang}
  title="Unione Italiana N°12 — Loggia Massonica Buenos Aires dal 1858"
  description="Loggia massonica regolare di Buenos Aires fondata nel 1858. Affiliata alla Gran Loggia dell'Argentina. Tempio Hijos del Trabajo, Barracas. Ingresso, petizioni e contatti."
  noTitleSuffix={true}
  schemaType="Organization"
  ogImageAlt="Delta Luminoso del Tempio Hijos del Trabajo — R∴L∴ Unione Italiana N°12, Loggia Massonica di Buenos Aires"
>
  <HeroTemple
    lang={lang}
    eyebrow={t("home.hero.eyebrow", lang)}
    title={t("home.hero.title", lang)}
    subtitle={t("home.hero.subtitle", lang)}
    ctaLabel={t("home.hero.cta", lang)}
    ctaHref="/it/la-loggia/tempio/"
  />

  <UpcomingEvent lang={lang} />

  <section class="container container-narrow" style="padding-block: var(--space-12);">
    <p class="lead drop-cap">
      Siamo una società filantropica, filosofica e progressista. Lavoriamo
      a Buenos Aires dal 23 dicembre 1858 (e∴v∴) — lo stesso anno in cui la Unione
      e Benevolenza apriva le sue porte sotto il padrinato simbolico di Mazzini e Garibaldi.
      Il nostro primo Presidente fu il medico genovese José Salvarezza, presente
      nell'assistenza durante il colera del 1867 (e∴v∴) e la febbre gialla del 1871 (e∴v∴). Rifondata
      nel 2014 (e∴v∴) da un nucleo preoccupato per l'assenza dell'Ordine a La Boca, la R∴L∴
      Unione Italiana N°12 sostiene oggi le sue riunioni nel storico Tempio Hijos del
      Trabajo di Barracas, affiliata alla Gran Loggia dell'Argentina dei Liberi
      e Accettati Massoni.
    </p>
  </section>

  <section class="container" style="padding-bottom: var(--space-12);">
    <PhotoSlider photos={sliderPhotos} aspect="16 / 9" autoplayMs={6000} />
  </section>

  <ThreeDoors
    doors={[
      { href: "/it/la-loggia/storia/", glyph: "columns", eyebrow: "MDCCCLVIII — Oggi", title: t("home.three_doors.history", lang), text: "Una storia documentata, non mitica. Dal Risorgimento alla rifondazione del 2014 (e∴v∴)." },
      { href: "/it/massoneria/cose/", glyph: "delta", eyebrow: "Un Ordine filosofico", title: t("home.three_doors.masonry", lang), text: "Cos'è —e cosa non è— la massoneria regolare. Senza segreti, con riserve." },
      { href: "/it/ingresso/", glyph: "square-compass", eyebrow: "Soglia del Postulante", title: t("home.three_doors.initiation", lang), text: "Se è arrivato qui per qualcosa più che curiosità passeggera, entri e legga con attenzione." },
    ]}
  />

  <RotatingQuote lang={lang} />

  <div class="divider-fleuron" aria-hidden="true">
    <span class="divider-fleuron-glyph">✦</span>
  </div>

  <ContactCTA lang={lang} variant="full" />
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--fg);
  }
</style>
