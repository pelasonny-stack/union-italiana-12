---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/content/PageHero.astro";
import MasonicGlyph from "../../components/symbols/MasonicGlyph.astro";
const lang = "it" as const;
---

<BaseLayout
  lang={lang}
  title="Contatti — Loggia Massonica Unione Italiana Buenos Aires"
  description="Contatto con la R∴L∴ Unione Italiana N°12: domande generali (unionitaliana12@gmail.com) e postulanti. Loggia massonica regolare, Barracas, Buenos Aires."
  breadcrumb={[{ name: "Contatti", url: "/it/contatti/" }]}
>
  <PageHero eyebrow="Due porte" title="Contatti" glyph="three-dots" />

  <section class="container" style="padding-block: var(--space-8);">
    <div class="contact-grid">
      <article class="contact-card">
        <MasonicGlyph name="three-dots" size={32} />
        <h3>Contatto generale</h3>
        <p>Consultazioni, visite, membri visitatori, stampa, ricerca accademica.</p>
        <a href="mailto:unionitaliana12@gmail.com" class="overline" style="margin-top: var(--space-3); display: inline-block;">unionitaliana12@gmail.com</a>
      </article>
      <article class="contact-card">
        <MasonicGlyph name="square-compass" size={32} />
        <h3>Postulanti</h3>
        <p>Se sta pensando di presentare domanda, le chiediamo di leggere prima la pagina di Ingresso.</p>
        <a href="/it/ingresso/" class="overline" style="margin-top: var(--space-3); display: inline-block;">Vai a Ingresso →</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); max-width: 880px; margin: 0 auto; }
  @media (max-width: 760px) { .contact-grid { grid-template-columns: 1fr; } }
  .contact-card { padding: var(--space-6); background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg); }
  .contact-card h3 { margin-block: var(--space-2); font-size: var(--text-h5); font-family: var(--font-display); }
  .contact-card p { color: var(--fg-muted); margin: 0; }
</style>
