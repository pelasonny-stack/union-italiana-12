---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "it" as const;
---

<BaseLayout lang={lang} title="Attività" description="Riunioni aperte, conferenze culturali, beneficenza.">
  <PageHero eyebrow="Il visibile" title="Attività" glyph="acacia" />
  <section class="container container-prose" style="padding-block: var(--space-8);">
    <p class="drop-cap">La Loggia lavora regolarmente in riunioni riservate ai suoi membri. Ma parte della sua vita avviene in pubblico: riunioni aperte, cicli culturali, opera di beneficenza.</p>
    <ul class="act-grid">
      <li><a href="/it/attivita/riunioni-bianche/">Riunioni aperte — calendario</a></li>
      <li><a href="/it/attivita/cultura/">Ciclo culturale</a></li>
      <li><a href="/it/attivita/beneficenza/">Beneficenza</a></li>
    </ul>
    <Stub note="Per iscriversi a una riunione aperta, scrivere a unionitaliana12@gmail.com." />
  </section>
</BaseLayout>

<style>
  .act-grid { list-style: none; padding: 0; margin-top: var(--space-6); }
  .act-grid li { padding-block: var(--space-2); border-bottom: 1px solid var(--border); }
</style>
