---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "it" as const;
---

<BaseLayout
  lang={lang}
  title="Riunioni Aperte — Tornate Bianche Pubbliche Buenos Aires"
  description="Riunioni aperte (tornate bianche) di Unione Italiana N°12: sessioni pubbliche al Tempio Hijos del Trabajo, Barracas. Calendario, iscrizione, relatori."
  breadcrumb={[
    { name: "Attività", url: "/it/attivita/" },
    { name: "Riunioni aperte", url: "/it/attivita/riunioni-aperte/" },
  ]}
>
  <PageHero eyebrow="Sessioni pubbliche" title="Riunioni aperte" glyph="three-dots" />
  <article class="container container-prose" style="padding-block: var(--space-8);">
    <p class="drop-cap">Le riunioni aperte sono sessioni pubbliche a cui la Loggia invita i non-massoni — di solito in occasione di una conferenza.</p>
    <Stub note="Il calendario delle prossime riunioni aperte sarà pubblicato a breve." />

    <p style="margin-top: var(--space-6); font-size: 0.85rem; color: var(--fg-muted); font-style: italic;">
      Ogni riunione aperta promossa da questo sito è autorizzata dalla Gran Loggia
      dell'Argentina dei Liberi e Accettati Massoni, conforme all'Art. 9° del
      Reglamento Especial para la Publicación de Páginas Web en Internet.
    </p>
  </article>
</BaseLayout>
