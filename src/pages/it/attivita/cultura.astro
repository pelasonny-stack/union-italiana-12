---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "it" as const;
---

<BaseLayout lang={lang} title="Ciclo culturale" description="Conferenze e presentazioni di libri.">
  <PageHero eyebrow="Cultura" title="Ciclo culturale" glyph="letter-g" />
  <article class="container container-prose" style="padding-block: var(--space-8);">
    <p class="drop-cap">La Loggia organizza, alternando con le sue tornate regolari, incontri culturali aperti al pubblico.</p>
    <Stub note="Prossime conferenze: in preparazione." />
  </article>
</BaseLayout>
