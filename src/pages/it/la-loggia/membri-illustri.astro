---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/content/PageHero.astro";
import NavRelated from "../../../components/content/NavRelated.astro";
import Stub from "../../../components/content/Stub.astro";
const lang = "it" as const;

const miembros = [
  { name: "José Ingenieros", years: "1877 (e∴v∴)—1925", role: "Medico, sociologo, saggista. Iniziato nell'Unione Italiana seguendo il padre.", confirmed: true },
  { name: "Salvatore Ingegnieros", years: "1850 (e∴v∴)—1924", role: "Giornalista, socialista della prima ora, padre di José. Immigrato siciliano.", confirmed: true },
  { name: "Giuseppe Garibaldi", years: "1807 (e∴v∴)—1882 (e∴v∴)", role: "Iniziato a Montevideo (1844 (e∴v∴)). Ombra tutelare di ogni loggia italiana del Río de la Plata, non membro di questa Loggia.", confirmed: false },
  { name: "Antonio Devoto", years: "1833 (e∴v∴)—1916", role: "Banchiere, fondatore del Banco di Italia e Río de la Plata, mecenate della collettività italiana.", confirmed: false },
];
---

<BaseLayout
  lang={lang}
  title="Membri Illustri — José Ingenieros, Salvarezza, Garibaldi"
  description="Membri illustri di Unione Italiana N°12: José Salvarezza (fondatore 1858 e∴v∴), José Ingenieros (filosofo, L'uomo mediocre), Salvatore Ingegnieros, Garibaldi."
  breadcrumb={[
    { name: "La Loggia", url: "/it/la-loggia/" },
    { name: "Membri illustri", url: "/it/la-loggia/membri-illustri/" },
  ]}
  article={{
    section: "Biografie",
    keywords: ["josé ingenieros massone", "josé salvarezza medico", "salvatore ingegnieros", "garibaldi massone", "massoni argentini illustri"],
  }}
>
  <PageHero eyebrow="Passato documentato" title="Membri illustri" subtitle="Solo persone defunte, solo membership documentata" glyph="letter-g" />
  <section class="container" style="padding-block: var(--space-8);">
    <ul class="miembros-grid">
      {miembros.map(m => (
        <li class="miembro-card">
          <p class="overline">{m.years}{m.confirmed ? " · Membro confermato" : " · Legame culturale"}</p>
          <h3>{m.name}</h3>
          <p class="role">{m.role}</p>
        </li>
      ))}
    </ul>
    <Stub note="La lista completa sarà pubblicata quando l'archivista della Loggia confermerà i registri del XIX secolo." />
  </section>

  <NavRelated
    lang={lang}
    prev={{ href: "/it/la-loggia/tempio/", label: "Il Tempio" }}
    index={{ href: "/it/la-loggia/", label: "La Loggia" }}
    next={{ href: "/it/la-loggia/auspici/", label: "Auspici GLA" }}
  />
</BaseLayout>

<style>
  .miembros-grid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-4); max-width: var(--container-default); margin: 0 auto; }
  .miembro-card { padding: var(--space-6); background: var(--bg-elevated); border: 1px solid var(--border); }
  .miembro-card h3 { margin: var(--space-1) 0; font-size: var(--text-h4); }
  .miembro-card .role { color: var(--fg-muted); margin: 0; }
</style>
