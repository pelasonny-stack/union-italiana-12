---
import "../styles/global.css";
import "../styles/transitions.css";
import { ClientRouter } from "astro:transitions";
import { LOCALE_LANG_TAG, type Locale } from "../i18n/config";

interface Props { lang: Locale; title: string; description: string }
const { lang, title, description } = Astro.props;
---

<!doctype html>
<html lang={LOCALE_LANG_TAG[lang]} data-locale={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#0b0b0f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body class="atrio-body">
    <slot />
  </body>
</html>

<style is:global>
  .atrio-body {
    background: var(--ink-900);
    color: var(--ivory-50);
    min-height: 100vh;
  }
</style>
