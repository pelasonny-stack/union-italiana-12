---
import "../styles/global.css";
import "../styles/transitions.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Llamador from "../components/layout/Llamador.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import EventJsonLd from "../components/seo/EventJsonLd.astro";
import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";
import ArticleJsonLd from "../components/seo/ArticleJsonLd.astro";
import { LOCALE_LANG_TAG, type Locale, alternateLocaleUrl } from "../i18n/config";
import { t, type UIKey } from "../i18n/ui";

interface Props {
  lang: Locale;
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  schemaType?: "Organization" | "WebSite";
  /** Si true, no agrega "· R∴L∴ Unión Italiana N°12" al title — usar cuando title ya está branded. */
  noTitleSuffix?: boolean;
  /** Breadcrumb items (sin home, se prepende automáticamente). Si se omite, no se inyecta breadcrumb schema. */
  breadcrumb?: Array<{ name: string; url: string }>;
  /** Article schema opcional para páginas de contenido (historia, qué-es, biblioteca). */
  article?: { datePublished?: string; dateModified?: string; section?: string; keywords?: string[] };
}

const {
  lang,
  title,
  description,
  ogImage = "/assets/templo/templo-1.jpeg",
  ogImageAlt,
  noindex = false,
  schemaType = "WebSite",
  noTitleSuffix = false,
  breadcrumb,
  article,
} = Astro.props;
const siteName = t("site.name", lang);
const fullTitle = noTitleSuffix || title === siteName || title.includes("Unión Italiana") || title.includes("Unione Italiana")
  ? title
  : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const altPath = alternateLocaleUrl(Astro.url.pathname, lang === "es" ? "it" : "es");
const altUrl = new URL(altPath, Astro.site).toString();
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
const finalOgAlt = ogImageAlt ?? (lang === "es"
  ? "Templo Hijos del Trabajo de Barracas — R∴L∴ Unión Italiana N°12"
  : "Tempio Hijos del Trabajo di Barracas — R∴L∴ Unione Italiana N°12");
---

<!doctype html>
<html lang={LOCALE_LANG_TAG[lang]} data-locale={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#0b0b0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4efe6" media="(prefers-color-scheme: light)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={LOCALE_LANG_TAG[lang]} href={canonical} />
    <link rel="alternate" hreflang={lang === "es" ? "it-IT" : "es-AR"} href={altUrl} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(Astro.url.pathname.replace(/^\/(es|it)/, "/es"), Astro.site).toString()}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* LCP preload — Hero del Templo (solo en home, WebP responsive) */}
    {Astro.url.pathname === "/es/" || Astro.url.pathname === "/it/" ? (
      <link
        rel="preload"
        as="image"
        href="/assets/templo/templo-3-1440w.webp"
        imagesrcset="/assets/templo/templo-3-480w.webp 480w, /assets/templo/templo-3-960w.webp 960w, /assets/templo/templo-3-1440w.webp 1440w, /assets/templo/templo-3-1920w.webp 1920w"
        imagesizes="100vw"
        type="image/webp"
        fetchpriority="high"
      />
    ) : null}

    {/* Web fonts — pesos podados (~150KB ahorrados vs full set) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cinzel:wght@400;500&family=EB+Garamond:ital,wght@0,400;1,400&family=Inter:wght@400;600&family=JetBrains+Mono:wght@400&family=IM+Fell+Flowers&display=swap"
    />

    {/* Open Graph */}
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={LOCALE_LANG_TAG[lang].replace("-", "_")} />
    <meta property="og:locale:alternate" content={lang === "es" ? "it_IT" : "es_AR"} />
    <meta property="og:site_name" content={siteName} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:secure_url" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:image:alt" content={finalOgAlt} />
      </>
    )}

    {/* Twitter / X cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={finalOgAlt} />}

    <JsonLd lang={lang} type={schemaType} />
    <EventJsonLd lang={lang} />
    {breadcrumb && breadcrumb.length > 0 && (
      <BreadcrumbJsonLd
        items={[
          { name: lang === "es" ? "Inicio" : "Home", url: lang === "es" ? "/es/" : "/it/" },
          ...breadcrumb,
        ]}
      />
    )}
    {article && (
      <ArticleJsonLd
        lang={lang}
        title={title}
        description={description}
        canonical={canonical}
        ogImage={ogImageUrl}
        datePublished={article.datePublished}
        dateModified={article.dateModified}
        section={article.section}
        keywords={article.keywords}
      />
    )}

    {/* Theme inicial — sin flash */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          if (saved === "dark" || saved === "light") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (_) {}
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">{t("skip.to_content" as UIKey, lang)}</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <Llamador lang={lang} />
  </body>
</html>
