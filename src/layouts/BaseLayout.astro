---
import "../styles/global.css";
import "../styles/transitions.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Llamador from "../components/layout/Llamador.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import EventJsonLd from "../components/seo/EventJsonLd.astro";
import { LOCALE_LANG_TAG, type Locale, alternateLocaleUrl } from "../i18n/config";
import { t, type UIKey } from "../i18n/ui";

interface Props {
  lang: Locale;
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  schemaType?: "Organization" | "WebSite";
}

const { lang, title, description, ogImage = "/assets/templo/templo-1.jpeg", noindex = false, schemaType = "WebSite" } = Astro.props;
const fullTitle = title === t("site.name", lang) ? title : `${title} · ${t("site.name", lang)}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const altPath = alternateLocaleUrl(Astro.url.pathname, lang === "es" ? "it" : "es");
const altUrl = new URL(altPath, Astro.site).toString();
---

<!doctype html>
<html lang={LOCALE_LANG_TAG[lang]} data-locale={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#0b0b0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4efe6" media="(prefers-color-scheme: light)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={LOCALE_LANG_TAG[lang]} href={canonical} />
    <link rel="alternate" hreflang={lang === "es" ? "it-IT" : "es-AR"} href={altUrl} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(Astro.url.pathname.replace(/^\/(es|it)/, "/es"), Astro.site).toString()}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* LCP preload — Hero del Templo (solo en home, WebP responsive) */}
    {Astro.url.pathname === "/es/" || Astro.url.pathname === "/it/" ? (
      <link
        rel="preload"
        as="image"
        href="/assets/templo/templo-3-1440w.webp"
        imagesrcset="/assets/templo/templo-3-480w.webp 480w, /assets/templo/templo-3-960w.webp 960w, /assets/templo/templo-3-1440w.webp 1440w, /assets/templo/templo-3-1920w.webp 1920w"
        imagesizes="100vw"
        type="image/webp"
        fetchpriority="high"
      />
    ) : null}

    {/* Web fonts — pesos podados (~150KB ahorrados vs full set) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cinzel:wght@400;500&family=EB+Garamond:ital,wght@0,400;1,400&family=Inter:wght@400;600&family=JetBrains+Mono:wght@400&family=IM+Fell+Flowers&display=swap"
    />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={LOCALE_LANG_TAG[lang].replace("-", "_")} />
    <meta property="og:site_name" content={t("site.name" as UIKey, lang)} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}

    <JsonLd lang={lang} type={schemaType} />
    <EventJsonLd lang={lang} />

    {/* Theme inicial — sin flash */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          if (saved === "dark" || saved === "light") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (_) {}
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">{t("skip.to_content" as UIKey, lang)}</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <Llamador lang={lang} />
  </body>
</html>
