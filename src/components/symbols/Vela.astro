---
/**
 * Vela SVG con llama titilante. Único elemento ceremonial del Atrio.
 * Apagada o encendida según prop. Honra prefers-reduced-motion.
 */
interface Props {
  lit?: boolean;
  size?: number;
  class?: string;
}
const { lit = true, size = 56, class: cls = "" } = Astro.props;
---

<svg
  width={size}
  height={size * 1.6}
  viewBox="0 0 56 90"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={`vela ${lit ? "is-lit" : "is-out"} ${cls}`}
>
  {/* Llama */}
  {lit && (
    <g class="flame">
      <path
        d="M28 8 C24 16 22 22 28 26 C34 22 32 16 28 8 Z"
        fill="#f5c878"
      />
      <path
        d="M28 14 C26 20 25 24 28 26 C31 24 30 20 28 14 Z"
        fill="#fff5d6"
      />
    </g>
  )}

  {/* Mecha */}
  <line x1="28" y1="28" x2="28" y2="34" stroke="#1a1a20" stroke-width="1.2" />

  {/* Cuerpo de la vela */}
  <rect x="22" y="34" width="12" height="50" rx="1.5" fill="#f4efe6" />
  <path d="M22 34 C22 32 24 31 28 31 C32 31 34 32 34 34 Z" fill="#e8e6e0" />

  {/* Halo cálido en modo lit */}
  {lit && (
    <circle
      cx="28"
      cy="20"
      r="22"
      fill="url(#vela-glow)"
      opacity="0.55"
      class="halo"
    />
  )}

  <defs>
    <radialGradient id="vela-glow" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%" stop-color="#f5c878" stop-opacity="0.6" />
      <stop offset="100%" stop-color="#f5c878" stop-opacity="0" />
    </radialGradient>
  </defs>
</svg>

<style>
  .vela.is-lit .flame {
    transform-origin: 28px 26px;
    animation: vela-titila 2.4s ease-in-out infinite;
  }
  .vela.is-lit .halo {
    animation: vela-halo 3s ease-in-out infinite;
  }
  @keyframes vela-titila {
    0%, 100% {
      transform: scale(1, 1) rotate(0deg);
      opacity: 1;
    }
    25% {
      transform: scale(0.95, 1.05) rotate(-1.5deg);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.05, 0.97) rotate(1.5deg);
      opacity: 1;
    }
    75% {
      transform: scale(0.97, 1.03) rotate(-1deg);
      opacity: 0.95;
    }
  }
  @keyframes vela-halo {
    0%, 100% {
      transform: scale(1);
      opacity: 0.55;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.7;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .vela.is-lit .flame,
    .vela.is-lit .halo {
      animation: none;
    }
  }
</style>
