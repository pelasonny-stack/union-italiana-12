---
import { t, type UIKey } from "../../i18n/ui";
import type { Locale } from "../../i18n/config";
import LangSwitcher from "./LangSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import MasonicGlyph from "../symbols/MasonicGlyph.astro";

interface Props { lang: Locale }
const { lang } = Astro.props;

const base = `/${lang}`;
const items: Array<{ href: string; key: UIKey; eyebrow?: string }> = [
  { href: `${base}/`, key: "nav.home" },
  { href: `${base}/${lang === "es" ? "la-logia" : "la-loggia"}/`, key: "nav.lodge", eyebrow: "1858" },
  { href: `${base}/${lang === "es" ? "masoneria" : "massoneria"}/`, key: "nav.masonry", eyebrow: lang === "es" ? "Orden filosófica" : "Ordine filosofico" },
  // Actividades temporalmente deshabilitadas
  // { href: `${base}/${lang === "es" ? "actividades" : "attivita"}/`, key: "nav.activities", eyebrow: lang === "es" ? "Reuniones abiertas" : "Riunioni aperte" },
  { href: `${base}/${lang === "es" ? "ingreso" : "ingresso"}/`, key: "nav.initiation", eyebrow: lang === "es" ? "Atrio del Peticionario" : "Atrio del Postulante" },
  { href: `${base}/${lang === "es" ? "contacto" : "contatti"}/`, key: "nav.contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const menuLabel = lang === "es" ? "Abrir menú" : "Apri menu";
const closeLabel = lang === "es" ? "Cerrar menú" : "Chiudi menu";
const navLabel = lang === "es" ? "Navegación principal" : "Navigazione principale";
const obedienceLabel = lang === "es"
  ? "Afiliada a de la Gran Logia de la Argentina"
  : "Affiliata a della Gran Loggia dell'Argentina";
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={`${base}/`} aria-label={t("site.name" as UIKey, lang)}>
      <img
        src="/assets/logos/union-italiana-12-logo.png"
        alt=""
        width="44"
        height="44"
        class="brand-logo"
        decoding="async"
        loading="eager"
        fetchpriority="high"
      />
      <span class="brand-text">
        <span class="cinzel">{lang === "es" ? "UNIÓN" : "UNIONE"} ITALIANA</span>
        <span class="cinzel brand-num">N° XII · MDCCCLVIII</span>
      </span>
    </a>

    {/* Nav desktop */}
    <nav aria-label={navLabel} class="primary-nav">
      <ul>
        {items.map(({ href, key }) => {
          const active = currentPath === href.replace(/\/$/, "");
          return (
            <li>
              <a href={href} aria-current={active ? "page" : undefined} class={active ? "is-active" : ""}>
                {t(key, lang)}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="header-actions">
      <LangSwitcher lang={lang} />
      <ThemeToggle lang={lang} />

      {/* Burger — solo mobile */}
      <button
        type="button"
        class="burger"
        aria-label={menuLabel}
        aria-expanded="false"
        aria-controls="mobile-drawer"
        data-burger
      >
        <span class="burger-bars" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>
</header>

{/* Drawer mobile fullscreen */}
<div
  id="mobile-drawer"
  class="mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label={navLabel}
  hidden
  data-drawer
>
  <div class="drawer-backdrop" data-drawer-close></div>

  <aside class="drawer-panel">
    <div class="drawer-head">
      <a class="brand" href={`${base}/`} data-drawer-link>
        <img
          src="/assets/logos/union-italiana-12-logo.png"
          alt=""
          width="40"
          height="40"
          class="brand-logo"
        />
        <span class="brand-text">
          <span class="cinzel">{lang === "es" ? "UNIÓN" : "UNIONE"} ITALIANA</span>
          <span class="cinzel brand-num">N° XII</span>
        </span>
      </a>
      <button type="button" class="drawer-close" aria-label={closeLabel} data-drawer-close>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M5 5 L19 19 M19 5 L5 19" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="drawer-nav" aria-label={navLabel}>
      <ul>
        {items.map(({ href, key, eyebrow }, i) => {
          const active = currentPath === href.replace(/\/$/, "");
          return (
            <li style={`--i:${i};`}>
              <a
                href={href}
                aria-current={active ? "page" : undefined}
                class={active ? "is-active" : ""}
                data-drawer-link
              >
                {eyebrow && <span class="overline drawer-eyebrow">{eyebrow}</span>}
                <span class="cinzel drawer-link-text">{t(key, lang)}</span>
                <span class="drawer-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="drawer-foot">
      <MasonicGlyph name="acacia" size={28} class="drawer-glyph" />
      <p class="overline drawer-obedience">{obedienceLabel}</p>
      <a href="https://www.masoneria-argentina.org.ar/" target="_blank" rel="noopener external" class="drawer-gla-link" data-drawer-link>
        masoneria-argentina.org.ar →
      </a>
    </div>
  </aside>
</div>

<script>
  const init = () => {
    const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
    const drawer = document.querySelector<HTMLElement>("[data-drawer]");
    if (!burger || !drawer) return;
    if (drawer.dataset.bound === "true") return;
    drawer.dataset.bound = "true";

    const root = document.documentElement;
    const closers = drawer.querySelectorAll<HTMLElement>("[data-drawer-close], [data-drawer-link]");
    let lastFocus: HTMLElement | null = null;

    const open = () => {
      lastFocus = document.activeElement as HTMLElement;
      drawer.hidden = false;
      requestAnimationFrame(() => drawer.dataset.open = "true");
      burger.setAttribute("aria-expanded", "true");
      root.style.overflow = "hidden";
      const first = drawer.querySelector<HTMLElement>("a, button");
      first?.focus();
    };

    const close = () => {
      drawer.dataset.open = "false";
      burger.setAttribute("aria-expanded", "false");
      root.style.overflow = "";
      const onEnd = () => {
        drawer.hidden = true;
        drawer.removeEventListener("transitionend", onEnd);
      };
      drawer.addEventListener("transitionend", onEnd);
      lastFocus?.focus();
    };

    burger.addEventListener("click", () => {
      drawer.hidden ? open() : close();
    });
    closers.forEach((el) => el.addEventListener("click", close));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !drawer.hidden) close();
    });

    // Close en navigation Astro
    document.addEventListener("astro:before-swap", () => {
      if (!drawer.hidden) {
        drawer.hidden = true;
        drawer.dataset.open = "false";
        burger.setAttribute("aria-expanded", "false");
        root.style.overflow = "";
      }
    });
  };
  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
    transition: padding var(--duration-normal) var(--ease-ceremonial);
  }
  .header-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-2);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--fg);
    background-image: none;
  }
  .brand:hover { background-size: 0; }
  .brand-logo { width: 44px; height: 44px; object-fit: contain; }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    font-size: 0.72rem;
    letter-spacing: var(--tracking-uppercase);
  }
  .brand-num { color: var(--accent); font-size: 0.62rem; }

  .primary-nav ul {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .primary-nav a {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-uppercase);
    font-weight: 600;
    color: var(--fg-muted);
    background-image: linear-gradient(var(--accent), var(--accent));
  }
  .primary-nav a:hover,
  .primary-nav a:focus-visible,
  .primary-nav a.is-active { color: var(--fg); }
  .primary-nav a.is-active { background-size: 100% 1px; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* Burger oculto en desktop */
  .burger {
    display: none;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    color: var(--fg);
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }
  .burger:hover, .burger:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }
  .burger-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }
  .burger-bars span {
    display: block;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--duration-normal) var(--ease-ceremonial),
                opacity var(--duration-fast);
  }
  .burger[aria-expanded="true"] .burger-bars span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .burger[aria-expanded="true"] .burger-bars span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] .burger-bars span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  /* ────────── DRAWER ────────── */

  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: flex-end;
  }
  .mobile-drawer[hidden] { display: none; }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(11, 11, 15, 0.6);
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-ceremonial);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .mobile-drawer[data-open="true"] .drawer-backdrop { opacity: 1; }

  .drawer-panel {
    position: relative;
    width: min(420px, 88vw);
    height: 100%;
    background: var(--ink-900);
    color: var(--ivory-50);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-slow) var(--ease-ceremonial);
    box-shadow: -16px 0 48px rgba(0, 0, 0, 0.4);
    overflow-y: auto;
  }
  .mobile-drawer[data-open="true"] .drawer-panel { transform: translateX(0); }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid color-mix(in srgb, var(--gold-700) 25%, transparent);
  }
  .drawer-head .brand-text { color: var(--ivory-50); }
  .drawer-head .brand-num { color: var(--gold-700); }

  .drawer-close {
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--gold-700) 30%, transparent);
    color: var(--ivory-50);
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }
  .drawer-close:hover { color: var(--gold-700); border-color: var(--gold-700); }

  .drawer-nav { flex: 1; padding: var(--space-4) 0; }
  .drawer-nav ul { list-style: none; padding: 0; margin: 0; }
  .drawer-nav li {
    border-bottom: 1px solid color-mix(in srgb, var(--gold-700) 12%, transparent);
  }
  .drawer-nav a {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    color: var(--ivory-50);
    background-image: none;
    transition: background-color var(--duration-fast), color var(--duration-fast);
  }
  .drawer-nav a:hover, .drawer-nav a:focus-visible {
    background: color-mix(in srgb, var(--gold-700) 8%, transparent);
    color: var(--gold-700);
  }
  .drawer-nav a.is-active {
    background: color-mix(in srgb, var(--gold-700) 14%, transparent);
    color: var(--gold-700);
  }
  .drawer-eyebrow {
    grid-column: 1;
    color: var(--gold-700);
    font-size: 0.65rem;
    margin-bottom: 4px;
  }
  .drawer-link-text {
    grid-column: 1;
    font-size: 1.05rem;
    font-weight: 500;
  }
  .drawer-arrow {
    grid-row: 1 / -1;
    grid-column: 2;
    color: var(--gold-700);
    opacity: 0.5;
    transition: transform var(--duration-fast), opacity var(--duration-fast);
  }
  .drawer-nav a:hover .drawer-arrow,
  .drawer-nav a:focus-visible .drawer-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* Reveal stagger items */
  @media (prefers-reduced-motion: no-preference) {
    .mobile-drawer[data-open="true"] .drawer-nav li {
      opacity: 0;
      transform: translateX(16px);
      animation: drawer-item-in 400ms var(--ease-ceremonial) forwards;
      animation-delay: calc(200ms + var(--i) * 50ms);
    }
    @keyframes drawer-item-in {
      to { opacity: 1; transform: none; }
    }
  }

  .drawer-foot {
    padding: var(--space-4);
    text-align: center;
    border-top: 1px solid color-mix(in srgb, var(--gold-700) 20%, transparent);
    background: color-mix(in srgb, var(--ink-800) 50%, transparent);
  }
  .drawer-glyph { color: var(--gold-700); margin: 0 auto var(--space-2); opacity: 0.7; }
  .drawer-obedience {
    color: var(--ink-300);
    font-size: 0.65rem;
    margin: 0 0 var(--space-1);
  }
  .drawer-gla-link {
    color: var(--gold-700);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background-image: none;
  }
  .drawer-gla-link:hover { color: var(--ivory-50); }

  /* ────────── Breakpoint ────────── */

  @media (max-width: 900px) {
    .primary-nav { display: none; }
    .burger { display: inline-flex; }
    .header-row { grid-template-columns: 1fr auto; }
    .brand-text { display: none; }
  }

  @media (max-width: 480px) {
    .brand-logo { width: 36px; height: 36px; }
    .header-actions :global(.lang-switcher) { font-size: 0.7rem; }
  }
</style>
