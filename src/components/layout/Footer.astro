---
import type { Locale } from "../../i18n/config";
import { t, type UIKey } from "../../i18n/ui";
import GLABadge from "./GLABadge.astro";

interface Props { lang: Locale }
const { lang } = Astro.props;
const base = `/${lang}`;
const obedienceHref = lang === "es" ? `${base}/la-logia/auspicios/` : `${base}/la-loggia/auspici/`;

const links = lang === "es"
  ? {
      institutional: [
        { href: `${base}/la-logia/`, label: "Quiénes somos" },
        { href: `${base}/la-logia/historia/`, label: "Historia" },
        { href: `${base}/la-logia/vinculo-italiano/`, label: "Vínculo italiano" },
        { href: obedienceHref, label: "Afiliación (GLA)" },
      ],
      resources: [
        { href: `${base}/masoneria/glosario/`, label: "Glosario" },
        { href: `${base}/masoneria/biblioteca/`, label: "Biblioteca" },
      ],
      initiation: [
        { href: `${base}/iniciacion/`, label: "¿Es para mí?" },
        { href: `${base}/iniciacion/peticion/`, label: "Atrio del Peticionario" },
        { href: `${base}/contacto/`, label: "Contacto" },
      ],
      legal: [
        { href: `${base}/legal/privacidad/`, label: t("footer.privacy" as UIKey, lang) },
        { href: `${base}/legal/terminos/`, label: t("footer.terms" as UIKey, lang) },
        { href: `${base}/legal/aviso-reglamentario/`, label: "Aviso reglamentario (GLA)" },
      ],
    }
  : {
      institutional: [
        { href: `${base}/la-loggia/`, label: "Chi siamo" },
        { href: `${base}/la-loggia/storia/`, label: "Storia" },
        { href: `${base}/la-loggia/legame-italiano/`, label: "Legame italiano" },
        { href: obedienceHref, label: "Affiliazione (GLA)" },
      ],
      resources: [
        { href: `${base}/massoneria/glossario/`, label: "Glossario" },
        { href: `${base}/massoneria/biblioteca/`, label: "Biblioteca" },
      ],
      initiation: [
        { href: `${base}/iniziazione/`, label: "È per me?" },
        { href: `${base}/iniziazione/petizione/`, label: "Atrio del Postulante" },
        { href: `${base}/contatti/`, label: "Contatti" },
      ],
      legal: [
        { href: `${base}/legale/privacy/`, label: t("footer.privacy" as UIKey, lang) },
        { href: `${base}/legale/termini/`, label: t("footer.terms" as UIKey, lang) },
        { href: `${base}/legale/avviso-regolamentare/`, label: "Avviso regolamentare (GLA)" },
      ],
    };
---

<footer class="site-footer">
  {/* Rule tricolor full-width — signature italianidad */}
  <div class="footer-tricolor" aria-hidden="true"></div>

  {/* Sello de afiliación GLA enmarcado */}
  <div class="footer-obedience">
    <div class="container">
      <GLABadge lang={lang} variant="full" />
    </div>
  </div>

  {/* ───── Identidad — fila propia, horizontal ───── */}
  <div class="footer-identity">
    <div class="container footer-identity-inner">
      <img
        src="/assets/logos/union-italiana-12-logo.png"
        alt=""
        width="64"
        height="64"
        class="footer-shield"
        loading="lazy"
      />
      <div class="identity-text">
        <p class="identity-name overline">{t("site.name" as UIKey, lang)}</p>
        <p class="identity-lema latin">
          {lang === "es" ? "Libertad, Igualdad, Fraternidad" : "Libertà, Uguaglianza, Fraternità"}
        </p>
        <p class="identity-foundation">{t("footer.foundation" as UIKey, lang)}</p>
      </div>
    </div>
  </div>

  {/* ───── Grid de links — 4 columnas iguales ───── */}
  <div class="container footer-grid">
    <div>
      <h6 class="overline">{t("footer.institutional" as UIKey, lang)}</h6>
      <ul>{links.institutional.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>
    <div>
      <h6 class="overline">{t("footer.resources" as UIKey, lang)}</h6>
      <ul>{links.resources.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>
    <div>
      <h6 class="overline">{t("footer.initiation" as UIKey, lang)}</h6>
      <ul>{links.initiation.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>
    <div>
      <h6 class="overline">{t("footer.legal" as UIKey, lang)}</h6>
      <ul>{links.legal.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
    </div>
  </div>

  {/* ───── Meta — dirección + redes en horizontal ───── */}
  <div class="footer-meta">
    <div class="container footer-meta-inner">
      <address class="meta-address">
        <span class="meta-label overline">{lang === "es" ? "Trabaja en el Templo" : "Lavora nel Tempio"}</span>
        <span class="meta-temple">Hijos del Trabajo</span>
        <span class="meta-line">San Antonio 814 · Barracas · CABA · Argentina</span>
        <a
          class="meta-map-link"
          href="https://www.openstreetmap.org/?mlat=-34.640&mlon=-58.379#map=17/-34.640/-58.379"
          target="_blank"
          rel="noopener external"
        >
          <span class="meta-map-rule" aria-hidden="true"></span>
          {lang === "es" ? "Ver en el mapa" : "Vedi sulla mappa"} →
        </a>
      </address>

      <div class="meta-social">
        <p class="meta-label overline">{lang === "es" ? "Seguinos" : "Seguici"}</p>
        <ul class="footer-social">
          <li>
            <a
              href="https://www.instagram.com/unionitaliana12/"
              target="_blank"
              rel="noopener external"
              aria-label="Instagram @unionitaliana12"
              title="Instagram @unionitaliana12"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.42a3.7 3.7 0 0 1 1.37.9c.43.42.7.84.9 1.36.16.42.36 1.06.42 2.23.05 1.25.07 1.65.07 4.85s0 3.6-.07 4.85a6 6 0 0 1-.42 2.23c-.2.52-.47.94-.9 1.37-.43.43-.85.7-1.37.9-.42.16-1.06.36-2.23.42-1.25.05-1.65.07-4.85.07s-3.6 0-4.85-.07c-1.17-.06-1.8-.26-2.23-.42a3.7 3.7 0 0 1-1.37-.9 3.7 3.7 0 0 1-.9-1.37 6 6 0 0 1-.42-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.42-2.23.2-.52.47-.94.9-1.37.43-.42.85-.7 1.37-.9.42-.16 1.06-.36 2.23-.42C8.4 2.22 8.8 2.2 12 2.2zm0 1.95c-3.14 0-3.51 0-4.75.07-1.07.05-1.65.23-2.04.38-.5.2-.86.43-1.24.81a3.3 3.3 0 0 0-.81 1.24c-.15.39-.33.97-.38 2.04C2.7 9.95 2.68 10.32 2.68 12c0 1.68 0 2.05.07 3.3.05 1.07.23 1.65.38 2.04.2.5.43.86.81 1.24.38.38.74.61 1.24.81.39.15.97.33 2.04.38 1.24.07 1.6.07 4.75.07s3.51 0 4.75-.07c1.07-.05 1.65-.23 2.04-.38.5-.2.86-.43 1.24-.81.38-.38.61-.74.81-1.24.15-.39.33-.97.38-2.04.07-1.25.07-1.62.07-3.3s0-2.05-.07-3.3c-.05-1.07-.23-1.65-.38-2.04a3.3 3.3 0 0 0-.81-1.24 3.3 3.3 0 0 0-1.24-.81c-.39-.15-.97-.33-2.04-.38-1.24-.07-1.6-.07-4.75-.07zm0 3.32a4.53 4.53 0 1 1 0 9.06 4.53 4.53 0 0 1 0-9.06zm0 1.95a2.58 2.58 0 1 0 0 5.16 2.58 2.58 0 0 0 0-5.16zm4.76-2.18a1.06 1.06 0 1 1 0 2.12 1.06 1.06 0 0 1 0-2.12z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* ───── Disclaimer reglamentario (Art. 7° Reglamento GLA) ───── */}
  <div class="footer-disclaimer">
    <div class="container">
      <p>
        {lang === "es"
          ? "El contenido de cualquier artículo, y/o material de correo adjunto es la opinión, o las opiniones de los autores, y no es de manera alguna interpretado como siendo de la autoridad Francmasónica en general o de una Logia en particular, o la Francmasonería Universal. Cada autor contribuye, y es su propia opinión. Pues tales ellos no son portavoces oficiales de la Francmasonería en su totalidad."
          : "Il contenuto di qualsiasi articolo e/o materiale di posta allegato è l'opinione, o le opinioni degli autori, e non è in alcun modo interpretato come proveniente dall'autorità Massonica in generale o di una Loggia in particolare, o dalla Massoneria Universale. Ciascun autore contribuisce con la propria opinione. Essi non sono portavoce ufficiali della Massoneria nella sua totalità."}
      </p>
    </div>
  </div>

  {/* ───── Baseline ───── */}
  <div class="footer-baseline">
    <div class="container">
      <p class="lema-spaced">A∴ L∴ G∴ D∴ G∴ A∴ D∴ U∴</p>
      <hr class="tricolor-rule" />
      <p class="footer-copy">© MMXXV (e∴v∴) · BUENOS AIRES · SUB ROSA</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-16);
    background: var(--bg-elevated);
    color: var(--fg-muted);
  }
  .footer-tricolor {
    width: 100%;
    height: 6px;
    background: var(--tricolor-horizontal);
  }
  .footer-obedience {
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--border);
  }

  /* ── Identidad ── */
  .footer-identity {
    padding-block: var(--space-6) var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .footer-identity-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .footer-shield {
    width: 64px;
    height: 64px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .identity-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.3;
  }
  .identity-name { margin: 0; }
  .identity-lema {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--fg);
    margin: 2px 0;
    font-size: 1.05rem;
  }
  .identity-foundation {
    font-size: var(--text-body-sm);
    color: var(--fg-subtle);
    margin: 0;
  }

  /* ── Grid 4 columnas iguales ── */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    padding-block: var(--space-8);
  }
  .footer-grid h6 {
    color: var(--fg);
    margin-bottom: var(--space-3);
  }
  .footer-grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .footer-grid a {
    font-size: var(--text-body-sm);
    color: var(--fg-muted);
  }
  .footer-grid a:hover { color: var(--accent); }

  /* ── Meta horizontal: address + social ── */
  .footer-meta {
    border-top: 1px solid var(--border);
    padding-block: var(--space-6);
  }
  .footer-meta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: var(--space-6);
  }
  .meta-label {
    color: var(--accent);
    font-size: 0.65rem;
    margin: 0 0 var(--space-1);
    display: block;
  }
  .meta-address {
    font-style: normal;
    font-size: var(--text-body-sm);
    color: var(--fg-muted);
    line-height: 1.55;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .meta-temple {
    color: var(--fg);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.3;
  }
  .meta-line { color: var(--fg-muted); }
  .meta-map-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    background-image: none;
    align-self: flex-start;
  }
  .meta-map-link:hover, .meta-map-link:focus-visible { color: var(--accent-bright); }
  .meta-map-rule {
    display: inline-block;
    width: 16px;
    height: 1px;
    background: currentColor;
    transition: width var(--duration-fast) var(--ease-ceremonial);
  }
  .meta-map-link:hover .meta-map-rule { width: 28px; }

  .meta-social {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }
  .meta-social .meta-label {
    text-align: right;
    width: 100%;
  }

  .footer-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
  }
  .footer-social a {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    background-image: none;
    transition: color var(--duration-fast), border-color var(--duration-fast);
    position: relative;
  }
  .footer-social a:hover { color: var(--accent); border-color: var(--accent); }
  .footer-social a::before {
    content: "⸫";
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    color: var(--accent);
    font-size: 0.7rem;
    opacity: 0;
    transition: opacity var(--duration-fast), transform var(--duration-fast) var(--ease-ceremonial);
    pointer-events: none;
  }
  .footer-social a:hover::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Disclaimer reglamentario ── */
  .footer-disclaimer {
    border-top: 1px solid var(--border);
    padding-block: var(--space-5);
    background: color-mix(in srgb, var(--bg) 92%, var(--accent) 8%);
  }
  .footer-disclaimer p {
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--fg-muted);
    text-align: justify;
    max-width: 78ch;
    margin: 0 auto;
    font-style: italic;
  }

  /* ── Baseline ── */
  .footer-baseline {
    border-top: 1px solid var(--border);
    padding-block: var(--space-6);
    text-align: center;
  }
  .lema-spaced {
    font-family: var(--font-cinzel);
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-3);
    padding-left: 0.4em;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-subtle);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: var(--space-3) 0 0;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
    .footer-meta-inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .meta-social { align-items: flex-start; }
    .meta-social .meta-label { text-align: left; }
  }
  @media (max-width: 540px) {
    .footer-identity-inner {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
