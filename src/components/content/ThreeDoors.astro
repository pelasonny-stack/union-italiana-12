---
/**
 * Tres pórticos — cards con frontón triangular, columnas laterales,
 * medallón circular del glyph, basa inferior. Ceremonia arquitectónica.
 */
import MasonicGlyph from "../symbols/MasonicGlyph.astro";
import type { GlyphName } from "../symbols/glyphs";

interface Door {
  href: string;
  glyph: GlyphName;
  eyebrow: string;
  title: string;
  text: string;
}

interface Props {
  doors: [Door, Door, Door];
}
const { doors } = Astro.props;
---

<section class="three-doors">
  <div class="container">
    <div class="doors-grid">
      {doors.map(d => (
        <a href={d.href} class="door">
          {/* Frontón triangular SVG */}
          <svg class="door-pediment" viewBox="0 0 88 22" aria-hidden="true">
            <path d="M0 22 L44 0 L88 22" stroke="currentColor" stroke-width="1" fill="none" />
          </svg>

          {/* Columnas izquierda y derecha (filete vertical con capitel) */}
          <span class="door-col door-col-left" aria-hidden="true"></span>
          <span class="door-col door-col-right" aria-hidden="true"></span>

          {/* Medallón con glyph */}
          <span class="door-medallion">
            <MasonicGlyph name={d.glyph} size={36} class="door-glyph" />
          </span>

          <p class="overline door-eyebrow">{d.eyebrow}</p>
          <h3 class="door-title">{d.title}</h3>
          <p class="door-text">{d.text}</p>

          <span class="door-cue" aria-hidden="true">
            <span class="door-cue-rule"></span>
            <span class="door-cue-arrow">▸</span>
          </span>

          {/* Basa inferior */}
          <span class="door-base" aria-hidden="true"></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .three-doors {
    padding-block: var(--space-16);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .doors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 900px) { .doors-grid { grid-template-columns: 1fr; } }

  .door {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: 48px 32px 36px;
    min-height: 380px;
    background: linear-gradient(180deg,
      var(--bg-elevated) 0%,
      color-mix(in srgb, var(--travertino) 50%, var(--bg-elevated)) 100%);
    color: var(--fg);
    background-image: linear-gradient(180deg,
      var(--bg-elevated) 0%,
      color-mix(in srgb, var(--travertino) 50%, var(--bg-elevated)) 100%);
    transition:
      transform var(--duration-slow) var(--ease-ceremonial),
      box-shadow var(--duration-slow) var(--ease-ceremonial);
  }
  .door:hover, .door:focus-visible {
    transform: translateY(-6px);
    box-shadow: var(--shadow-elevated);
  }

  .door-pediment {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 88px;
    height: 22px;
    color: var(--accent);
    transition: color var(--duration-slow) var(--ease-ceremonial);
  }
  .door:hover .door-pediment { color: var(--vermiglio); }

  .door-col {
    position: absolute;
    top: 24px;
    bottom: 18px;
    width: 1px;
    background: linear-gradient(180deg,
      transparent 0,
      var(--accent) 8%,
      var(--accent) 92%,
      transparent 100%);
    opacity: 0.55;
  }
  .door-col-left { left: 12px; }
  .door-col-right { right: 12px; }

  .door-medallion {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--accent);
    display: grid;
    place-items: center;
    margin-bottom: var(--space-4);
    transition: transform var(--duration-slow) var(--ease-ceremonial);
  }
  .door:hover .door-medallion { transform: rotate(3deg); }
  .door-glyph { color: var(--accent); }

  .door-eyebrow {
    color: var(--accent);
    margin: 0;
  }
  .door-title {
    font-family: var(--font-display);
    font-size: var(--text-h4);
    font-weight: 500;
    margin: var(--space-1) 0;
    line-height: 1.15;
  }
  .door-text {
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .door-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-4);
    color: var(--accent);
  }
  .door-cue-rule {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: currentColor;
    transition: width var(--duration-slow) var(--ease-ceremonial);
  }
  .door-cue-arrow {
    transition: transform var(--duration-fast) var(--ease-ceremonial);
  }
  .door:hover .door-cue-rule { width: 56px; }
  .door:hover .door-cue-arrow { transform: translateX(6px); }

  .door-base {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    height: 2px;
    background: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .door:hover .door-medallion,
    .door:hover .door-cue-arrow { transform: none; }
  }
</style>
