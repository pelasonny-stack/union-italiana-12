---
/**
 * Hero principal — masthead editorial asimétrico.
 * Nastro tricolor vertical (signature italianidad) + tipografía 3 niveles
 * (overline Cinzel, "Unión Italiana" Cormorant, "N° 12" Cinzel).
 * Foto del Templo respira con overlay degradado horizontal.
 */
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
  eyebrow: string;
  title: string;
  subtitle: string;
  ctaLabel: string;
  ctaHref: string;
  bgSrc?: string;
  bgAlt?: string;
}

const {
  lang,
  eyebrow,
  title,
  subtitle,
  ctaLabel,
  ctaHref,
  bgSrc = "/assets/templo/templo-3.jpeg",
  bgAlt = "Interior del Templo Hijos del Trabajo, sede actual de la Logia",
} = Astro.props;

const bgBase = bgSrc.replace(/\.(jpe?g|png|webp)$/i, "");
const bgSrcsetWebp = [480, 960, 1440, 1920].map((w) => `${bgBase}-${w}w.webp ${w}w`).join(", ");
const bgSrcsetJpeg = [480, 960, 1440, 1920].map((w) => `${bgBase}-${w}w.jpeg ${w}w`).join(", ");
const bgSizes = "100vw";

// Datestamp ceremonial — año romano + Anno Verae Lucis
const today = new Date();
const toRoman = (n: number): string => {
  const m: [number, string][] = [[1000, "M"], [900, "CM"], [500, "D"], [400, "CD"], [100, "C"], [90, "XC"], [50, "L"], [40, "XL"], [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"]];
  let s = ""; let r = n;
  for (const [v, c] of m) { while (r >= v) { s += c; r -= v; } }
  return s;
};
const year = today.getUTCFullYear();
const sinceFoundation = year - 1858;
const sinceRefounding = year - 2014;
const masthead = `BUENOS AIRES · ${toRoman(year)} (e∴v∴)`;
const stamp = `${String(today.getUTCDate()).padStart(2, "0")} · ${toRoman(today.getUTCMonth() + 1)} · ${toRoman(year)} (e∴v∴) — ${year + 4000} A∴ V∴ L∴`;
const anniversaries = lang === "es"
  ? `Año ${toRoman(sinceRefounding)} desde la refundación · ${toRoman(sinceFoundation)} desde la fundación`
  : `Anno ${toRoman(sinceRefounding)} dalla rifondazione · ${toRoman(sinceFoundation)} dalla fondazione`;
const firstVisitLabel = lang === "es" ? "¿Primera visita?" : "Prima visita?";
const firstVisitHref = lang === "es"
  ? "/es/masoneria/que-es/#en-ocho-segundos"
  : "/it/massoneria/cose/#in-otto-secondi";

// "Unión Italiana" — separar en 2 partes para tratamiento tipográfico mixto
const titleParts = title.split(" ");
const wordmarkOne = titleParts.slice(0, -1).join(" "); // "Unión" o similar
const wordmarkTwo = titleParts.slice(-1).join(" ");    // última palabra
---

<section class="hero-temple">
  {/* Foto Templo — fondo */}
  <picture class="hero-picture">
    <source type="image/webp" srcset={bgSrcsetWebp} sizes={bgSizes} />
    <source type="image/jpeg" srcset={bgSrcsetJpeg} sizes={bgSizes} />
    <img class="hero-bg" src={bgSrc} alt={bgAlt} width="1920" height="1280" fetchpriority="high" decoding="async" />
  </picture>
  <div class="hero-overlay" aria-hidden="true"></div>

  {/* Nastro tricolor vertical — signature visual del sitio */}
  <div class="nastro" aria-hidden="true">
    <span class="nastro-fleuron">✦</span>
  </div>

  <div class="hero-temple-inner container">
    <div class="hero-text">
      <span class="hero-rule" aria-hidden="true"></span>
      <p class="hero-invocation cinzel" aria-label="A la Gloria del Gran Arquitecto del Universo">A∴ L∴ G∴ D∴ G∴ A∴ D∴ U∴</p>
      <p class="hero-masthead">{masthead}</p>

      <h1 class="hero-h1">
        <span class="cinzel hero-eyebrow-line">{lang === "es" ? "RESPETABLE LOGIA" : "RISPETTABILE LOGGIA"}</span>
        <span class="hero-name">{title}</span>
        <span class="cinzel hero-num">N° XII · MDCCCLVIII (e∴v∴)</span>
      </h1>

      <div class="hero-auspices-block">
        <img
          src="/assets/logos/gran-logia-argentina-2025.png"
          alt="Logo de la Gran Logia de la Argentina de Libres y Aceptados Masones"
          width="180"
          height="70"
          class="hero-auspices-logo"
          loading="eager"
          decoding="async"
        />
        <p class="hero-auspices cinzel">
          {lang === "es"
            ? "Bajo los auspicios de la Gran Logia de la Argentina de Libres y Aceptados Masones"
            : "Sotto gli auspici della Gran Loggia dell'Argentina dei Liberi e Accettati Massoni"}
        </p>
      </div>

      <p class="hero-subtitle latin">{subtitle}</p>

      <a href={ctaHref} class="hero-cta cinzel">
        <span class="hero-bar"></span>
        <span>{ctaLabel}</span>
      </a>

      <p class="hero-stamp">
        {stamp}
        <span class="hero-stamp-divider" aria-hidden="true">·</span>
        <a href={firstVisitHref} class="hero-first-visit">{firstVisitLabel} →</a>
      </p>
      <p class="hero-anniversaries">{anniversaries}</p>
    </div>
  </div>

  <div class="hero-scroll-cue" aria-hidden="true">
    <svg viewBox="0 0 24 32" width="20" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 4 L12 28 M6 22 L12 28 L18 22" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .hero-temple {
    position: relative;
    min-height: clamp(620px, 92vh, 920px);
    scroll-margin-top: 120px;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    color: var(--candela);
    background: var(--notte);
    isolation: isolate;
  }

  .hero-picture {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    filter: contrast(1.05) saturate(0.9);
    animation: hero-zoom 24s var(--ease-ceremonial) both;
  }
  @keyframes hero-zoom {
    from { transform: scale(1.06); }
    to { transform: scale(1); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg,
        rgba(15, 12, 18, 0.92) 0%,
        rgba(15, 12, 18, 0.72) 40%,
        rgba(15, 12, 18, 0.35) 70%,
        rgba(15, 12, 18, 0.18) 100%);
  }

  /* Nastro tricolor vertical — pegado al edge izq, full height del hero */
  .nastro {
    position: absolute;
    top: 0;
    left: clamp(16px, 3vw, 32px);
    bottom: 0;
    width: 8px;
    z-index: 2;
    background: var(--tricolor-vertical);
    box-shadow:
      0 0 0 1px rgba(15, 12, 18, 0.4),
      var(--shadow-elevated);
  }
  .nastro-fleuron {
    position: absolute;
    left: 50%;
    top: 33%;
    transform: translate(-50%, -50%);
    color: var(--accent-bright);
    font-size: 1.2rem;
    text-shadow: 0 0 8px rgba(15, 12, 18, 0.8);
    background: var(--notte);
    padding: 4px;
    border: 1px solid var(--accent);
    line-height: 1;
  }

  .hero-temple-inner {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    padding-block: clamp(80px, 12vh, 160px);
    padding-left: clamp(48px, 8vw, 120px) !important;
  }
  .hero-text {
    max-width: 720px;
  }

  .hero-rule {
    display: block;
    width: 88px;
    height: 1px;
    background: var(--accent);
    margin-bottom: var(--space-2);
  }

  .hero-invocation {
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    color: var(--accent-bright);
    text-align: center;
    opacity: 0.85;
    margin: 0 0 var(--space-2);
  }

  .hero-masthead {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--candela);
    opacity: 0.72;
    margin: 0 0 var(--space-4);
  }

  .hero-auspices-block {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-4);
    flex-wrap: wrap;
  }
  .hero-auspices-logo {
    width: clamp(110px, 18vw, 180px);
    height: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
  }
  .hero-auspices {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--accent-bright);
    opacity: 0.9;
    margin: 0;
    max-width: 56ch;
    flex: 1 1 280px;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.95;
    margin: 0 0 var(--space-4);
    color: var(--candela);
  }
  .hero-eyebrow-line {
    display: block;
    font-size: clamp(0.95rem, 1.4vw, 1.25rem);
    color: var(--accent-bright);
    margin-bottom: var(--space-2);
  }
  .hero-name {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(3.4rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--candela);
    text-wrap: balance;
  }
  .hero-num {
    display: block;
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    color: var(--candela);
    opacity: 0.85;
    margin-top: var(--space-2);
    letter-spacing: 0.18em;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    color: var(--accent-bright);
    margin: 0 0 var(--space-6);
    max-width: 38ch;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--candela);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    background-image: none;
    border: 1px solid var(--accent);
    padding: var(--space-2) var(--space-4);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    transition:
      background var(--duration-fast) var(--ease-ceremonial),
      border-color var(--duration-fast) var(--ease-ceremonial),
      color var(--duration-fast) var(--ease-ceremonial);
    margin-bottom: var(--space-8);
  }
  .hero-cta:hover, .hero-cta:focus-visible {
    color: var(--candela);
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    border-color: var(--accent-bright);
  }
  .hero-bar {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: currentColor;
    transition: width var(--duration-slow) var(--ease-ceremonial);
  }
  .hero-cta:hover .hero-bar,
  .hero-cta:focus-visible .hero-bar { width: 56px; }

  .hero-stamp {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--candela);
    opacity: 0.6;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6em;
    align-items: baseline;
  }
  .hero-stamp-divider { opacity: 0.4; }
  .hero-first-visit {
    color: var(--accent-bright);
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    text-transform: uppercase;
    transition: opacity var(--duration-fast);
  }
  .hero-first-visit:hover, .hero-first-visit:focus-visible {
    opacity: 0.85;
  }
  .hero-anniversaries {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--candela);
    opacity: 0.45;
    margin: var(--space-1) 0 0;
    letter-spacing: 0.02em;
  }

  .hero-scroll-cue {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    z-index: 3;
    color: var(--accent-bright);
    opacity: 0.5;
    animation: scroll-cue 2.4s ease-in-out infinite;
  }
  @keyframes scroll-cue {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50%      { transform: translateY(6px); opacity: 0.8; }
  }

  /* Stagger reveal del bloque texto */
  @media (prefers-reduced-motion: no-preference) {
    .hero-rule, .hero-masthead, .hero-h1, .hero-subtitle, .hero-cta, .hero-stamp, .hero-anniversaries {
      opacity: 0;
      transform: translateY(12px);
      animation: hero-in 800ms var(--ease-ceremonial) forwards;
    }
    .hero-rule         { animation-delay: 200ms; }
    .hero-masthead     { animation-delay: 350ms; }
    .hero-h1           { animation-delay: 500ms; }
    .hero-subtitle     { animation-delay: 950ms; }
    .hero-cta          { animation-delay: 1200ms; }
    .hero-stamp        { animation-delay: 1450ms; }
    .hero-anniversaries { animation-delay: 1600ms; }
    @keyframes hero-in {
      to { opacity: 1; transform: none; }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-bg { animation: none; }
    .hero-scroll-cue { animation: none; }
  }

  /* Mobile: nastro pasa a top horizontal 6px (mantener prominencia) */
  @media (max-width: 768px) {
    .nastro {
      top: 0;
      left: 0;
      right: 0;
      bottom: auto;
      width: auto;
      height: 6px;
      background: var(--tricolor-horizontal);
    }
    .nastro-fleuron { display: none; }
    .hero-temple-inner { padding-left: clamp(24px, 6vw, 48px) !important; }
  }
</style>
