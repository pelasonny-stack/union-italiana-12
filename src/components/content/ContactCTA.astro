---
/**
 * Bloque CTA de contacto — agregable al final de cualquier página
 * para empujar conversión. Muestra dos opciones: contacto general
 * + Atrio del Peticionario.
 */
import type { Locale } from "../../i18n/config";

interface Props { lang: Locale; variant?: "full" | "compact" }
const { lang, variant = "full" } = Astro.props;

const isES = lang === "es";
const base = `/${lang}`;

const text = isES
  ? {
      eyebrow: "Contacto",
      title: "¿Querés conocernos más?",
      lead: "Recibimos consultas de personas interesadas en la masonería, periodistas, académicos y peticionarios serios. La candidatura siempre parte del interesado.",
      contactLabel: "Escribir a la Logia",
      contactDesc: "Consultas, prensa, miembros visitantes",
      contactHref: `${base}/contacto/`,
      petitionLabel: "Atrio del Peticionario",
      petitionDesc: "Iniciar el proceso de petición · XXIII umbrales",
      petitionHref: `${base}/ingreso/`,
      mailLabel: "unionitaliana12@gmail.com",
    }
  : {
      eyebrow: "Contatti",
      title: "Vuoi conoscerci meglio?",
      lead: "Riceviamo consultazioni di persone interessate alla massoneria, giornalisti, accademici e postulanti seri. La candidatura parte sempre dall'interessato.",
      contactLabel: "Scrivere alla Loggia",
      contactDesc: "Consultazioni, stampa, membri visitatori",
      contactHref: `${base}/contatti/`,
      petitionLabel: "Atrio del Postulante",
      petitionDesc: "Iniziare il processo · XXIII soglie",
      petitionHref: `${base}/ingresso/`,
      mailLabel: "unionitaliana12@gmail.com",
    };
---

<section class={`contact-cta ${variant}`} aria-labelledby="contact-cta-title">
  <div class="container container-narrow cta-inner">
    <p class="overline cta-eyebrow">{text.eyebrow}</p>
    <h2 id="contact-cta-title" class="cta-title">{text.title}</h2>
    {variant === "full" && <p class="cta-lead">{text.lead}</p>}

    <div class="cta-grid">
      <a href={text.contactHref} class="cta-card cta-card--secondary">
        <span class="cta-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="6" width="18" height="13" />
            <path d="M3 7 L12 14 L21 7" />
          </svg>
        </span>
        <span class="cta-text">
          <span class="cta-label cinzel">{text.contactLabel}</span>
          <span class="cta-desc">{text.contactDesc}</span>
          <span class="cta-mail">{text.mailLabel}</span>
        </span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>

      <a href={text.petitionHref} class="cta-card cta-card--primary">
        <span class="cta-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 L4 21" />
            <path d="M12 3 L20 21" />
            <circle cx="12" cy="3" r="0.8" fill="currentColor" />
            <path d="M5 19 L19 19 L19 13" />
          </svg>
        </span>
        <span class="cta-text">
          <span class="cta-label cinzel">{text.petitionLabel}</span>
          <span class="cta-desc">{text.petitionDesc}</span>
        </span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    padding-block: var(--space-12);
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
  }
  .contact-cta.compact {
    padding-block: var(--space-8);
  }
  .cta-inner {
    text-align: center;
  }
  .cta-eyebrow {
    color: var(--accent);
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3vw, 2.6rem);
    font-style: italic;
    font-weight: 500;
    color: var(--fg);
    margin-block: var(--space-2) var(--space-3);
  }
  .cta-lead {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 56ch;
    margin: 0 auto var(--space-6);
  }
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    max-width: 760px;
    margin: 0 auto;
    text-align: left;
  }
  @media (max-width: 720px) {
    .cta-grid { grid-template-columns: 1fr; gap: var(--space-4); }
  }
  .cta-card {
    display: grid;
    grid-template-columns: 44px 1fr 24px;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--accent);
    background: var(--bg);
    color: var(--fg);
    background-image: none;
    transition:
      transform var(--duration-normal) var(--ease-ceremonial),
      box-shadow var(--duration-normal) var(--ease-ceremonial),
      background var(--duration-normal) var(--ease-ceremonial);
  }
  .cta-card:hover, .cta-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }
  .cta-card--primary {
    background: var(--vermiglio);
    color: var(--candela);
    border-color: var(--accent-bright);
  }
  .cta-card--primary:hover { background: var(--vermiglio-profondo); }

  .cta-icon {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    color: var(--accent);
    flex-shrink: 0;
  }
  .cta-card--primary .cta-icon { color: var(--accent-bright); }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.3;
    min-width: 0;
  }
  .cta-label {
    font-size: 0.85rem;
    color: inherit;
  }
  .cta-desc {
    font-size: 0.78rem;
    color: var(--fg-muted);
    font-family: var(--font-sans);
  }
  .cta-card--primary .cta-desc { color: color-mix(in srgb, var(--candela) 75%, transparent); }
  .cta-mail {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    margin-top: 2px;
  }
  .cta-arrow {
    color: var(--accent);
    font-size: 1.1rem;
    transition: transform var(--duration-fast) var(--ease-ceremonial);
  }
  .cta-card--primary .cta-arrow { color: var(--accent-bright); }
  .cta-card:hover .cta-arrow { transform: translateX(4px); }
</style>
