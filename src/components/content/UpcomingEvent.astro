---
/**
 * Banda viva — próxima Tenida pública.
 * Lee de src/data/upcoming-event.json. Si no hay evento futuro o
 * isPublic=false, retorna null (no se renderiza).
 */
import type { Locale } from "../../i18n/config";
import event from "../../data/upcoming-event.json";

interface Props { lang: Locale }
const { lang } = Astro.props;

// Computar si renderizar
const eventDate = new Date(event.date);
const now = new Date();
const diffMs = eventDate.getTime() - now.getTime();
const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
const shouldRender = event.isPublic && diffDays >= 0;

// Romanos util
const toRoman = (n: number): string => {
  const m: [number, string][] = [[1000, "M"], [900, "CM"], [500, "D"], [400, "CD"], [100, "C"], [90, "XC"], [50, "L"], [40, "XL"], [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"]];
  let s = ""; let r = n;
  for (const [v, c] of m) { while (r >= v) { s += c; r -= v; } }
  return s;
};

const dayOfMonth = String(eventDate.getUTCDate()).padStart(2, "0");
const monthRoman = toRoman(eventDate.getUTCMonth() + 1);
const yearRoman = toRoman(eventDate.getUTCFullYear());
const dateStr = `${dayOfMonth}·${monthRoman}·${yearRoman}`;

const title = lang === "it" ? event.title.it : event.title.es;
const kind = lang === "it" ? event.kind.it : event.kind.es;

const labels = lang === "es"
  ? {
      eyebrow: "Próxima sesión pública",
      countdown: diffDays === 0
        ? "Hoy"
        : diffDays === 1
        ? "Mañana"
        : `Faltan ${toRoman(diffDays)} días`,
      cta: "Inscribirse",
    }
  : {
      eyebrow: "Prossima sessione pubblica",
      countdown: diffDays === 0
        ? "Oggi"
        : diffDays === 1
        ? "Domani"
        : `Mancano ${toRoman(diffDays)} giorni`,
      cta: "Iscriversi",
    };

const contactHref = lang === "es" ? "/es/contacto/" : "/it/contatti/";
---

{shouldRender && (
  <aside class="upcoming-event" aria-label={labels.eyebrow}>
    <div class="container ue-inner">
      <div class="ue-marker" aria-hidden="true">
        <span class="ue-pulse"></span>
      </div>
      <div class="ue-text">
        <span class="overline ue-eyebrow">{labels.eyebrow} · {kind}</span>
        <span class="ue-title">{title}</span>
      </div>
      <div class="ue-meta">
        <span class="ue-date">{dateStr}</span>
        <span class="ue-divider" aria-hidden="true">·</span>
        <span class="ue-countdown">{labels.countdown}</span>
      </div>
      <a href={event.rsvpUrl ?? contactHref} class="ue-cta cinzel">{labels.cta} →</a>
    </div>
  </aside>
)}

<style>
  .upcoming-event {
    background: var(--travertino);
    border-top: 1px solid var(--accent);
    border-bottom: 1px solid var(--border);
    color: var(--fg);
  }
  :root[data-theme="dark"] .upcoming-event {
    background: color-mix(in srgb, var(--notte-elev) 90%, var(--vermiglio));
  }
  .ue-inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-2);
    flex-wrap: wrap;
  }
  .ue-marker {
    flex-shrink: 0;
    position: relative;
    width: 10px;
    height: 10px;
  }
  .ue-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--vermiglio);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--vermiglio) 60%, transparent);
    animation: ue-pulse 2.4s ease-in-out infinite;
  }
  @keyframes ue-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--vermiglio) 60%, transparent); }
    50%      { box-shadow: 0 0 0 6px color-mix(in srgb, var(--vermiglio) 0%, transparent); }
  }

  .ue-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .ue-eyebrow {
    color: var(--fg-muted);
    font-size: 0.65rem;
  }
  .ue-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--fg);
    line-height: 1.3;
  }

  .ue-meta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    flex-shrink: 0;
  }
  .ue-date { color: var(--accent); }
  .ue-divider { opacity: 0.5; }

  .ue-cta {
    flex-shrink: 0;
    color: var(--accent);
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    font-size: 0.72rem;
    transition: opacity var(--duration-fast);
  }
  .ue-cta:hover, .ue-cta:focus-visible { opacity: 0.7; }

  @media (prefers-reduced-motion: reduce) {
    .ue-pulse { animation: none; }
  }
  @media (max-width: 720px) {
    .ue-meta, .ue-cta { font-size: 0.7rem; }
    .ue-title { font-size: 0.85rem; }
  }
</style>
