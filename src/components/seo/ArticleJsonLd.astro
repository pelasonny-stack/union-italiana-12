---
/**
 * JSON-LD Article para páginas de contenido (historia, qué-es, biblioteca).
 * Mejora indexación + featured snippets + Article rich result.
 */
import type { Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  datePublished?: string;
  dateModified?: string;
  section?: string;
  keywords?: string[];
}

const { lang, title, description, canonical, ogImage, datePublished, dateModified, section, keywords } = Astro.props;
const url = Astro.site?.toString() ?? "https://logiaunionitaliana12.com.ar/";
const isES = lang === "es";

const data: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonical}#article`,
  headline: title,
  description,
  url: canonical,
  inLanguage: isES ? "es-AR" : "it-IT",
  isPartOf: { "@id": `${url}#website` },
  publisher: { "@id": `${url}#organization` },
  author: { "@id": `${url}#organization` },
  mainEntityOfPage: canonical,
  datePublished: datePublished ?? "2025-01-01",
  dateModified: dateModified ?? new Date().toISOString().slice(0, 10),
};

if (ogImage) {
  data.image = {
    "@type": "ImageObject",
    url: ogImage,
    width: 1200,
    height: 630,
  };
}
if (section) data.articleSection = section;
if (keywords && keywords.length) data.keywords = keywords.join(", ");

// Speakable: hace que asistentes de voz lean el resumen del artículo.
data.speakable = {
  "@type": "SpeakableSpecification",
  cssSelector: ["h1", ".lead", ".drop-cap"],
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
