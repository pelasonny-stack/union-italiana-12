---
/**
 * JSON-LD BreadcrumbList — mejora rich snippets en Google.
 */
interface Props {
  items: Array<{ name: string; url: string }>;
}
const { items } = Astro.props;

const baseUrl = Astro.site?.toString() ?? "https://logiaunionitaliana12.com.ar/";

const data = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: item.name,
    item: item.url.startsWith("http") ? item.url : new URL(item.url, baseUrl).toString(),
  })),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
