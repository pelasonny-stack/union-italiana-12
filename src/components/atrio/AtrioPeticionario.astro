---
import Vela from "../symbols/Vela.astro";
import type { Locale } from "../../i18n/config";

interface Props { lang: Locale }
const { lang } = Astro.props;

const FORMSPREE_URL =
  import.meta.env.PUBLIC_FORMSPREE_URL ?? "https://formspree.io/f/mwpwwvpj";

const labels = lang === "es"
  ? {
      step1: "Etapa I — Identidad",
      step2: "Etapa II — Introspección",
      step3: "Etapa III — Palabra",
      next: "Cruzar el umbral",
      back: "Volver atrás",
      submit: "Enviar petición",
      heard: "Has sido escuchado.",
      sending: "Llamando…",
      ofThree: "de tres",
      // Step 1 fields
      firstName: "Nombre", lastName: "Apellido",
      dob: "Fecha de nacimiento", nationality: "Nacionalidad",
      docType: "Tipo de documento", docNumber: "Número",
      address: "Domicilio", city: "Ciudad", province: "Provincia", country: "País",
      phone: "Teléfono", email: "Correo electrónico",
      occupation: "Profesión u ocupación",
      occupationHelp: "Pedimos detalle, no rótulo. \"Comerciante\" dice menos que \"comerciante minorista de instrumentos musicales desde 2014\".",
      // Step 2
      religious: "¿Profesa alguna religión o tradición filosófica?",
      religiousHelp: "La masonería regular pide creencia en un Principio Creador, sin imponer dogma. Si quiere, describa con sus palabras su posición personal. No se evalúa por contenido confesional, sino por sinceridad.",
      howKnown: "¿Cómo conoció la masonería?",
      howKnownHelp: "Lecturas, familia, encuentros, búsquedas personales. Si lo desea, sea concreto: títulos de libros, nombres si los recuerda, momentos.",
      whyPetition: "¿Por qué peticiona?",
      whyPetitionHelp: "Esta es la pregunta central. Le pedimos que escriba con calma. No hay respuesta correcta — hay respuesta auténtica. (mín. 200 caracteres)",
      whyLodge: "¿Por qué la Unión Italiana N°12 y no otra Logia?",
      whyLodgeHelp: "Existen logias regulares en Buenos Aires con orientaciones diversas. ¿Qué lo trae específicamente a la nuestra?",
      // Step 3
      criminal: "¿Tiene antecedentes penales?",
      criminalDetail: "Si sí, describa brevemente",
      criminalHelp: "Una respuesta afirmativa no es automáticamente excluyente; una respuesta falsa, sí.",
      availability: "Disponibilidad horaria — días en que podría asistir a reuniones (en general, una noche entre semana, dos veces al mes)",
      contribution: "Capacidad de aporte mensual",
      contributionHelp: "La cuota se acuerda según posibilidades reales. La Logia no rechaza por situación económica, pero sí por opacidad.",
      contributionMin: "Mínimo (dificultades económicas)",
      contributionMid: "Medio (situación estable)",
      contributionLarge: "Amplio",
      contributionPnts: "Prefiero no decir",
      freeComment: "Comentario libre — lo que considere que no fue preguntado y debamos saber",
      declarationTruth: "Declaro bajo juramento que toda la información provista es veraz, y que peticiono libremente, sin haber sido inducido por terceros.",
      dataConsent: "He leído y acepto la Política de Privacidad. Autorizo el tratamiento de mis datos en los términos de la Ley 25.326. Conozco mi derecho a acceder, rectificar y suprimir.",
      privacyLink: "Ver política de privacidad",
      // Errors
      errorGeneric: "El llamado no llegó. Reintente en unos minutos.",
      errorRate: "Demasiados intentos. Intente más tarde.",
      errorTurnstile: "No pudimos verificar la solicitud. Recargue e intente de nuevo.",
      errorMissing: "Hay campos obligatorios sin completar.",
      errorTooShort: "Algunas respuestas son demasiado breves para evaluarlas con seriedad.",
    }
  : {
      step1: "Tappa I — Identità",
      step2: "Tappa II — Introspezione",
      step3: "Tappa III — Parola",
      next: "Varcare la soglia",
      back: "Tornare indietro",
      submit: "Inviare la petizione",
      heard: "Sei stato ascoltato.",
      sending: "Bussando…",
      ofThree: "di tre",
      firstName: "Nome", lastName: "Cognome",
      dob: "Data di nascita", nationality: "Nazionalità",
      docType: "Tipo di documento", docNumber: "Numero",
      address: "Indirizzo", city: "Città", province: "Provincia", country: "Paese",
      phone: "Telefono", email: "Email",
      occupation: "Professione od occupazione",
      occupationHelp: "Chiediamo dettaglio, non etichetta. \"Commerciante\" dice meno di \"commerciante al dettaglio di strumenti musicali dal 2014\".",
      religious: "Professa una religione o tradizione filosofica?",
      religiousHelp: "La massoneria regolare richiede la credenza in un Principio Creatore, senza imporre alcun dogma. Se vuole, descriva con parole proprie la sua posizione personale. Non si valuta per contenuto confessionale, ma per sincerità.",
      howKnown: "Come ha conosciuto la massoneria?",
      howKnownHelp: "Letture, famiglia, incontri, ricerche personali. Se desidera, sia concreto: titoli di libri, nomi, momenti.",
      whyPetition: "Perché presenta domanda?",
      whyPetitionHelp: "Questa è la domanda centrale. Le chiediamo di scrivere con calma. Non c'è risposta corretta — c'è risposta autentica. (min. 200 caratteri)",
      whyLodge: "Perché la Unione Italiana N°12 e non un'altra Loggia?",
      whyLodgeHelp: "Esistono logge regolari a Buenos Aires con orientamenti diversi. Cosa la porta specificamente alla nostra?",
      criminal: "Ha precedenti penali?",
      criminalDetail: "Se sì, descriva brevemente",
      criminalHelp: "Una risposta affermativa non è automaticamente escludente; una risposta falsa, sì.",
      availability: "Disponibilità oraria — giorni in cui potrebbe assistere alle riunioni (in genere, una sera infrasettimanale, due volte al mese)",
      contribution: "Capacità di contributo mensile",
      contributionHelp: "La quota si concorda secondo le possibilità reali. La Loggia non rifiuta per situazione economica, ma per opacità.",
      contributionMin: "Minima (difficoltà economiche)",
      contributionMid: "Media (situazione stabile)",
      contributionLarge: "Ampia",
      contributionPnts: "Preferisco non dire",
      freeComment: "Commento libero — ciò che ritiene non sia stato chiesto e dobbiamo sapere",
      declarationTruth: "Dichiaro sotto giuramento che tutte le informazioni fornite sono veritiere, e che presento domanda liberamente, senza essere stato indotto da terzi.",
      dataConsent: "Ho letto e accetto la Politica sulla Privacy. Autorizzo il trattamento dei miei dati ai sensi della Legge 25.326. Conosco il mio diritto di accesso, rettifica e cancellazione.",
      privacyLink: "Vedi politica sulla privacy",
      errorGeneric: "Il colpo non è giunto. Riprovare tra qualche minuto.",
      errorRate: "Troppi tentativi. Riprova più tardi.",
      errorTurnstile: "Non possiamo verificare la richiesta. Ricarica e riprova.",
      errorMissing: "Ci sono campi obbligatori non compilati.",
      errorTooShort: "Alcune risposte sono troppo brevi per essere valutate con serietà.",
    };
---

<div
  class="atrio"
  data-atrio
  data-lang={lang}
  data-formspree-url={FORMSPREE_URL}
  data-confirmation-url={lang === "es" ? "/es/ingreso/confirmacion/" : "/it/ingresso/conferma/"}
  data-i18n={JSON.stringify({
    generic: labels.errorGeneric,
    rate: labels.errorRate,
    missing: labels.errorMissing,
    tooShort: labels.errorTooShort,
    sending: labels.sending,
    submit: labels.submit,
    charsRemaining: lang === "es" ? "faltan" : "mancano",
    charsCount: lang === "es" ? "caracteres" : "caratteri",
    blocked: lang === "es" ? "Solicitud bloqueada." : "Richiesta bloccata.",
  })}
>
  <div class="atrio-stage" data-stage>
    {/* ────────── Velas indicador ────────── */}
    <div class="velas-row" aria-hidden="true">
      <Vela size={42} lit={true} />
      <Vela size={42} lit={false} class="vela-2" />
      <Vela size={42} lit={false} class="vela-3" />
    </div>

    <p class="step-counter overline" data-step-counter>
      <span data-step-current>1</span>
      <span style="margin: 0 0.4em">/</span>
      <span>3</span>
      <span style="margin-left: 0.6em">{labels.ofThree}</span>
    </p>

    <form id="atrio-form" novalidate>
      {/* honeypot — invisible para humanos */}
      <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="honeypot" />
      <input type="hidden" name="formStartedAt" value="" data-form-started />
      <input type="hidden" name="preferredLanguage" value={lang} />
      <input type="hidden" name="_subject" value={lang === "es" ? "Nueva petición — Atrio Unión Italiana N°12" : "Nuova petizione — Atrio Unione Italiana N°12"} />

      {/* ───────── UMBRAL I — IDENTIDAD ───────── */}
      <fieldset class="step is-active" data-step="1">
        <legend class="cinzel step-title">{labels.step1}</legend>

        <div class="grid-2">
          <label class="field"><span>{labels.firstName} *</span><input type="text" name="firstName" required aria-required="true" minlength="2" maxlength="60" autocomplete="given-name" /></label>
          <label class="field"><span>{labels.lastName} *</span><input type="text" name="lastName" required aria-required="true" minlength="2" maxlength="60" autocomplete="family-name" /></label>
        </div>

        <div class="grid-2">
          <label class="field"><span>{labels.dob}</span><input type="date" name="dateOfBirth" autocomplete="bday" /></label>
          <label class="field"><span>{labels.nationality}</span><input type="text" name="nationality" maxlength="120" /></label>
        </div>

        <div class="grid-2">
          <label class="field"><span>{labels.docType}</span>
            <select name="documentType">
              <option value="">—</option>
              <option value="DNI">DNI</option>
              <option value="Passport">Passport</option>
              <option value="CarnetIT">Carta d'Identità (IT)</option>
              <option value="Other">{lang === "es" ? "Otro" : "Altro"}</option>
            </select>
          </label>
          <label class="field"><span>{labels.docNumber}</span><input type="text" name="documentNumber" maxlength="40" /></label>
        </div>

        <label class="field"><span>{labels.address}</span><input type="text" name="address" maxlength="200" autocomplete="street-address" /></label>

        <div class="grid-3">
          <label class="field"><span>{labels.city}</span><input type="text" name="city" autocomplete="address-level2" /></label>
          <label class="field"><span>{labels.province}</span><input type="text" name="province" autocomplete="address-level1" /></label>
          <label class="field"><span>{labels.country}</span><input type="text" name="country" autocomplete="country-name" value={lang === "it" ? "Italia" : "Argentina"} /></label>
        </div>

        <div class="grid-2">
          <label class="field"><span>{labels.phone} *</span><input type="tel" name="phone" required aria-required="true" autocomplete="tel" /></label>
          <label class="field"><span>{labels.email} *</span><input type="email" name="email" required aria-required="true" autocomplete="email" /></label>
        </div>

        <label class="field">
          <span>{labels.occupation} *</span>
          <input type="text" name="occupation" required aria-required="true" minlength="3" maxlength="120" />
          <small>{labels.occupationHelp}</small>
        </label>

        <div class="step-nav">
          <span></span>
          <button type="button" class="next-btn cinzel" data-next>{labels.next} →</button>
        </div>
      </fieldset>

      {/* ───────── UMBRAL II — INTROSPECCIÓN ───────── */}
      <fieldset class="step" data-step="2">
        <legend class="cinzel step-title">{labels.step2}</legend>

        <label class="field">
          <span>{labels.religious}</span>
          <textarea name="religiousPosition" maxlength="1500" rows="5"></textarea>
          <small>{labels.religiousHelp}</small>
        </label>

        <label class="field">
          <span>{labels.howKnown}</span>
          <textarea name="howKnownMasonry" maxlength="1500" rows="5"></textarea>
          <small>{labels.howKnownHelp}</small>
        </label>

        <label class="field">
          <span>{labels.whyPetition} *</span>
          <textarea name="whyPetition" required aria-required="true" minlength="200" maxlength="3000" data-charcount="200" rows="8"></textarea>
          <small>{labels.whyPetitionHelp}</small>
        </label>

        <label class="field">
          <span>{labels.whyLodge}</span>
          <textarea name="whyThisLodge" maxlength="1500" rows="5"></textarea>
          <small>{labels.whyLodgeHelp}</small>
        </label>

        <div class="step-nav">
          <button type="button" class="back-btn" data-back>← {labels.back}</button>
          <button type="button" class="next-btn cinzel" data-next>{labels.next} →</button>
        </div>
      </fieldset>

      {/* ───────── UMBRAL III — PALABRA ───────── */}
      <fieldset class="step" data-step="3">
        <legend class="cinzel step-title">{labels.step3}</legend>

        <div class="grid-2">
          <label class="field"><span>{labels.criminal} *</span>
            <select name="criminalRecord" required aria-required="true">
              <option value="no">No</option>
              <option value="yes">{lang === "es" ? "Sí" : "Sì"}</option>
            </select>
          </label>
          <label class="field"><span>{labels.criminalDetail}</span><input type="text" name="criminalRecordDetail" maxlength="500" /></label>
        </div>
        <p class="help-block">{labels.criminalHelp}</p>

        <div class="field">
          <span>{labels.availability}</span>
          <div class="checkbox-row">
            {[
              ["lun", lang === "es" ? "Lun" : "Lun"],
              ["mar", lang === "es" ? "Mar" : "Mar"],
              ["mie", lang === "es" ? "Mié" : "Mer"],
              ["jue", lang === "es" ? "Jue" : "Gio"],
              ["vie", lang === "es" ? "Vie" : "Ven"],
              ["sab", lang === "es" ? "Sáb" : "Sab"],
              ["dom", lang === "es" ? "Dom" : "Dom"],
            ].map(([val, lbl]) => (
              <label class="check" for={`avail-${val}`}>
                <input type="checkbox" id={`avail-${val}`} name="availability" value={val} />
                <span>{lbl}</span>
              </label>
            ))}
          </div>
        </div>

        <label class="field">
          <span>{labels.contribution}</span>
          <select name="contributionRange">
            <option value="">—</option>
            <option value="minimo">{labels.contributionMin}</option>
            <option value="medio">{labels.contributionMid}</option>
            <option value="amplio">{labels.contributionLarge}</option>
            <option value="prefiero-no-decir">{labels.contributionPnts}</option>
          </select>
          <small>{labels.contributionHelp}</small>
        </label>

        <label class="field">
          <span>{labels.freeComment}</span>
          <textarea name="freeComment" maxlength="1500" rows="4"></textarea>
        </label>

        <label class="check check-block">
          <input type="checkbox" name="declarationTruth" required aria-required="true" />
          <span>{labels.declarationTruth}</span>
        </label>

        <label class="check check-block">
          <input type="checkbox" name="dataConsent" required aria-required="true" />
          <span>
            {labels.dataConsent}{" "}
            <a href={lang === "es" ? "/es/legal/privacidad/" : "/it/legale/privacy/"} target="_blank" rel="noopener">{labels.privacyLink}</a>
          </span>
        </label>

        <div class="step-nav">
          <button type="button" class="back-btn" data-back>← {labels.back}</button>
          <button type="submit" class="submit-btn cinzel" data-submit>{labels.submit}</button>
        </div>
      </fieldset>

      <p class="error-display" data-error-display role="alert" hidden></p>
    </form>
  </div>

  {/* Pantalla de "Has sido escuchado" */}
  <div class="atrio-heard" data-heard hidden>
    <svg class="heard-check" viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
      <circle cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="1.5" />
      <path d="M22 42 L34 54 L58 28" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="heard-check-path" />
    </svg>
    <p class="heard-text cinzel">{labels.heard}</p>
    <p class="heard-countdown" data-countdown aria-live="polite">
      {lang === "es" ? "Redirigiendo en " : "Reindirizzamento in "}<span data-countdown-num>3</span>
    </p>
  </div>
</div>

<script>
  type I18n = {
    generic: string; rate: string; missing: string; tooShort: string;
    sending: string; submit: string; charsRemaining: string; charsCount: string;
    blocked: string;
  };

  function initAtrio() {
    const root = document.querySelector("[data-atrio]") as HTMLElement | null;
    if (!root || root.dataset.atrioInited === "1") return;
    root.dataset.atrioInited = "1";

    const formspreeUrl = root.dataset.formspreeUrl ?? "";
    const confirmationUrl = root.dataset.confirmationUrl ?? "/";
    let i18n: I18n = { generic: "", rate: "", missing: "", tooShort: "", sending: "", submit: "", charsRemaining: "", charsCount: "", blocked: "" };
    try { i18n = { ...i18n, ...JSON.parse(root.dataset.i18n ?? "{}") }; } catch {}

    const form = root.querySelector("#atrio-form") as HTMLFormElement | null;
    if (!form) return;
    const steps = Array.from(root.querySelectorAll("fieldset[data-step]")) as HTMLElement[];
    const counter = root.querySelector("[data-step-current]") as HTMLElement | null;
    const errorDisplay = root.querySelector("[data-error-display]") as HTMLElement | null;
    const heardScreen = root.querySelector("[data-heard]") as HTMLElement | null;
    const stage = root.querySelector("[data-stage]") as HTMLElement | null;

    const startedInput = root.querySelector("[data-form-started]") as HTMLInputElement | null;
    if (startedInput) startedInput.value = String(Date.now());

    // Char counters para textareas con data-charcount
    root.querySelectorAll<HTMLTextAreaElement>("textarea[data-charcount]").forEach((ta) => {
      const min = Number(ta.getAttribute("data-charcount") ?? "0");
      const counterEl = document.createElement("small");
      counterEl.className = "char-counter";
      counterEl.setAttribute("aria-live", "polite");
      ta.insertAdjacentElement("afterend", counterEl);
      const update = () => {
        const len = ta.value.length;
        const remaining = Math.max(0, min - len);
        if (len === 0) {
          counterEl.textContent = `0 / ${min} ${i18n.charsCount}`;
          counterEl.dataset.state = "empty";
        } else if (remaining > 0) {
          counterEl.textContent = `${len} / ${min} · ${i18n.charsRemaining} ${remaining}`;
          counterEl.dataset.state = "below";
        } else {
          counterEl.textContent = `${len} ${i18n.charsCount} ✓`;
          counterEl.dataset.state = "ok";
        }
      };
      ta.addEventListener("input", update);
      update();
    });

    // Inline validation per-field on blur
    const inlineFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(
      "input[required], textarea[required], select[required]"
    );
    inlineFields.forEach((el) => {
      el.addEventListener("blur", () => {
        if (!el.value) return;
        if (!el.checkValidity()) el.classList.add("is-invalid");
        else el.classList.remove("is-invalid");
      });
      el.addEventListener("input", () => {
        if (el.classList.contains("is-invalid") && el.checkValidity()) {
          el.classList.remove("is-invalid");
        }
      });
    });

    let current = 1;
    function show(step: number) {
      steps.forEach((el) => {
        const n = Number(el.getAttribute("data-step"));
        el.classList.toggle("is-active", n === step);
      });
      if (counter) counter.textContent = String(step);
      root!.querySelectorAll(".velas-row .vela").forEach((v, idx) => {
        v.classList.toggle("is-lit", idx < step);
        v.classList.toggle("is-out", idx >= step);
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
      current = step;
    }

    function showError(msg: string) {
      if (!errorDisplay) return;
      errorDisplay.hidden = false;
      errorDisplay.textContent = msg;
    }
    function clearError() {
      if (!errorDisplay) return;
      errorDisplay.hidden = true;
      errorDisplay.textContent = "";
    }

    function validateStep(step: number): boolean {
      const fieldset = root!.querySelector(`fieldset[data-step="${step}"]`);
      if (!fieldset) return false;
      const required = fieldset.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(
        "input[required], textarea[required], select[required]"
      );
      const invalid: (HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)[] = [];
      for (const el of required) {
        if (!el.checkValidity()) {
          el.classList.add("is-invalid");
          invalid.push(el);
        }
      }
      if (invalid.length === 0) {
        clearError();
        return true;
      }
      showError(i18n.missing);
      const first = invalid[0];
      first.scrollIntoView({ behavior: "smooth", block: "center" });
      first.focus({ preventScroll: true });
      first.reportValidity();
      return false;
    }

    root.querySelectorAll("[data-next]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!validateStep(current)) return;
        if (current < 3) show(current + 1);
      });
    });
    root.querySelectorAll("[data-back]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (current > 1) show(current - 1);
      });
    });

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      if (!validateStep(3)) return;

      const submitBtn = root!.querySelector("[data-submit]") as HTMLButtonElement | null;
      if (!submitBtn) return;

      // Honeypot triggered → block + show msg
      const honeypot = form!.querySelector("[name=website]") as HTMLInputElement | null;
      if (honeypot?.value) {
        submitBtn.disabled = true;
        showError(i18n.blocked);
        return;
      }

      const originalLabel = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.classList.add("is-sending");
      submitBtn.textContent = i18n.sending;
      clearError();

      if (!formspreeUrl) {
        showError(i18n.generic);
        submitBtn.disabled = false;
        submitBtn.classList.remove("is-sending");
        submitBtn.textContent = originalLabel;
        return;
      }

      const fd = new FormData(form!);
      const availability = fd.getAll("availability").join(", ");
      fd.delete("availability");
      if (availability) fd.append("availability", availability);

      try {
        const res = await fetch(formspreeUrl, {
          method: "POST",
          headers: { "Accept": "application/json" },
          body: fd,
        });
        await res.json().catch(() => ({}));
        if (!res.ok) {
          const msg = res.status === 429 ? i18n.rate : i18n.generic;
          showError(msg);
          submitBtn.disabled = false;
          submitBtn.classList.remove("is-sending");
          submitBtn.textContent = originalLabel;
          return;
        }

        if (stage) {
          stage.style.transition = "opacity 1.2s var(--ease-ceremonial, ease-in-out)";
          stage.style.opacity = "0";
        }
        setTimeout(() => {
          if (stage) stage.hidden = true;
          if (heardScreen) {
            heardScreen.hidden = false;
            heardScreen.style.opacity = "0";
            requestAnimationFrame(() => {
              heardScreen.style.transition = "opacity 1.2s var(--ease-ceremonial, ease-in-out)";
              heardScreen.style.opacity = "1";
              heardScreen.classList.add("is-revealed");
            });
          }
          // Countdown visible 3...2...1
          const countNum = root!.querySelector("[data-countdown-num]") as HTMLElement | null;
          let n = 3;
          if (countNum) {
            countNum.textContent = String(n);
            const tick = window.setInterval(() => {
              n -= 1;
              if (n <= 0) { window.clearInterval(tick); return; }
              countNum.textContent = String(n);
            }, 1000);
          }
          setTimeout(() => {
            window.location.href = confirmationUrl;
          }, 3200);
        }, 900);
      } catch (e) {
        showError(i18n.generic);
        submitBtn.disabled = false;
        submitBtn.classList.remove("is-sending");
        submitBtn.textContent = originalLabel;
      }
    });
  }

  initAtrio();
  document.addEventListener("astro:page-load", initAtrio);
</script>

<style>
  .atrio {
    min-height: 100vh;
    background: var(--ink-900);
    color: var(--ivory-50);
    padding: var(--space-8) var(--space-3);
    font-family: var(--font-sans);
  }
  .atrio-stage {
    max-width: 720px;
    margin: 0 auto;
  }
  .velas-row {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .step-counter {
    text-align: center;
    color: var(--gold-700);
    margin-bottom: var(--space-6);
  }

  .step {
    border: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: none;
  }
  .step.is-active { display: block; }
  .step-title {
    font-size: var(--text-h4);
    color: var(--gold-700);
    margin-bottom: var(--space-6);
    text-align: center;
    width: 100%;
  }

  .field {
    display: block;
    margin-bottom: var(--space-4);
  }
  .field span {
    display: block;
    font-size: 0.85rem;
    color: var(--ink-200);
    margin-bottom: var(--space-1);
  }
  .field input,
  .field textarea,
  .field select {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(192, 155, 82, 0.3);
    color: var(--ivory-50);
    padding: var(--space-2);
    border-radius: 2px;
    font-size: 1rem;
    line-height: 1.5;
    transition: border-color var(--duration-fast) var(--ease-ceremonial);
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    outline: none;
    border-color: var(--gold-700);
  }
  .field input.is-invalid, .field textarea.is-invalid, .field select.is-invalid {
    border-color: #c97a78;
    background: rgba(122, 46, 42, 0.08);
  }
  .char-counter {
    display: block;
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-300);
  }
  .char-counter[data-state="below"] { color: #c97a78; }
  .char-counter[data-state="ok"] { color: var(--gold-700); }
  .field textarea {
    resize: vertical;
    min-height: 6em;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
  .field small {
    display: block;
    margin-top: var(--space-1);
    color: var(--ink-300);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-3); }
  @media (max-width: 640px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }

  .help-block {
    color: var(--ink-300);
    font-size: 0.8rem;
    margin: calc(-1 * var(--space-2)) 0 var(--space-4);
  }

  .checkbox-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .check {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(192, 155, 82, 0.3);
    cursor: pointer;
    font-size: 0.85rem;
  }
  .check input { width: auto; margin: 0; }
  .check-block {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    background: transparent;
    border: none;
    padding: var(--space-2) 0;
    font-size: 0.9rem;
    color: var(--ink-200);
  }
  .check-block input { margin-top: 0.25rem; }
  .check-block a { color: var(--gold-700); }


  .step-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(192, 155, 82, 0.2);
  }

  .next-btn, .submit-btn, .back-btn {
    background: transparent;
    color: var(--gold-700);
    border: 1px solid var(--gold-700);
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    font-size: 0.85rem;
    transition:
      background-color var(--duration-normal) var(--ease-ceremonial),
      color var(--duration-normal) var(--ease-ceremonial);
  }
  .next-btn:hover, .submit-btn:hover {
    background: var(--gold-700);
    color: var(--ink-900);
  }
  .submit-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    background: rgba(192, 155, 82, 0.08);
  }
  .submit-btn.is-sending {
    cursor: wait;
    position: relative;
    animation: sending-pulse 1.4s ease-in-out infinite;
  }
  @keyframes sending-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 0.85; }
  }
  @media (prefers-reduced-motion: reduce) {
    .submit-btn.is-sending { animation: none; }
  }
  .back-btn {
    border-color: var(--ink-500);
    color: var(--ink-300);
  }
  .back-btn:hover { color: var(--ivory-50); border-color: var(--ivory-50); }

  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .error-display {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    background: rgba(122, 46, 42, 0.15);
    border: 1px solid var(--it-red);
    color: #f4cdc8;
    font-size: 0.9rem;
  }

  .atrio-heard {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
  }
  .heard-check {
    color: var(--gold-700);
  }
  .heard-check-path {
    stroke-dasharray: 70;
    stroke-dashoffset: 70;
  }
  .atrio-heard.is-revealed .heard-check-path {
    animation: heard-check-draw 0.9s var(--ease-ceremonial) forwards;
  }
  @keyframes heard-check-draw {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .atrio-heard.is-revealed .heard-check-path { animation: none; stroke-dashoffset: 0; }
  }
  .heard-text {
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--gold-700);
    text-align: center;
  }
  .heard-countdown {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--ink-300);
    margin-top: var(--space-2);
  }

  /* Step transition (motion guarded explícitamente) */
  @media (prefers-reduced-motion: no-preference) {
    .step.is-active {
      animation: step-in var(--duration-ritual) var(--ease-ceremonial);
    }
    @keyframes step-in {
      from { opacity: 0; filter: blur(8px); transform: translateY(8px); }
      to { opacity: 1; filter: blur(0); transform: none; }
    }
  }
</style>
